@page
@model FinanceME.Areas.Identity.Pages.Account.LoginWith2faModel
@{
    Layout = null;
    ViewData["Title"] = "Two-Factor Authentication";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceME</title>
    <link rel="icon" type="image/png" href="~/Logo/logo_transparent.png" />
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-page">
    <main class="auth-shell">
        <aside class="auth-brand" aria-label="Two-factor verification details">
            <div>
                <div class="auth-brand__masthead">
                    <a asp-controller="Home" asp-action="Index" class="auth-brand__logo" aria-label="FinanceME home">
                        <img src="~/Logo/logo_transparent.png" alt="FinanceME logo" />
                        <span class="auth-brand__wordmark">Finance<span>ME</span></span>
                    </a>
                    <span class="auth-kicker">Verification Gate</span>
                </div>
                <h1 class="auth-brand__title">Confirm identity <em>before entry</em>.</h1>
                <p class="auth-brand__copy">Two-factor authentication is the last line of defence. Your financial data stays protected even if your password is compromised.</p>
            </div>

            <div class="auth-steps">
                <div class="auth-step">
                    <span class="index">01</span>
                    <span class="label">Email verified</span>
                </div>
                <div class="auth-step active">
                    <span class="index">02</span>
                    <span class="label">Enter 2FA code</span>
                </div>
                <div class="auth-step">
                    <span class="index">03</span>
                    <span class="label">Access granted</span>
                </div>
            </div>

            <div class="auth-proof-list">
                <div class="auth-proof-item">
                    <span class="label">2FA Method</span>
                    <span class="value">Authenticator App (TOTP)</span>
                </div>
                <div class="auth-proof-item">
                    <span class="label">Code Validity</span>
                    <span class="value warning">30 seconds per code</span>
                </div>
                <div class="auth-proof-item">
                    <span class="label">Session Security</span>
                    <span class="value positive">AES-256 · Encrypted at rest</span>
                </div>
            </div>

            <p class="auth-brand__footnote">Never share your 2FA code with anyone &bull; FinanceME will never call or email to ask for it</p>
        </aside>


        <section class="auth-stage">
            <div class="auth-panel">
                <a asp-page="./Login" class="auth-back-link" aria-label="Back to login page">
                    <span aria-hidden="true">&larr;</span>
                    Back to Login
                </a>

                <header class="auth-panel__head">
                    <h2 class="auth-panel__title">Two-Factor Authentication</h2>
                    <p class="auth-panel__subtitle">Enter your authenticator code to finish signing in.</p>
                </header>

                <form method="post" class="auth-form" novalidate>
                    <input asp-for="ReturnUrl" type="hidden" />
                    <input asp-for="RememberMe" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="auth-status error"></div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Input.TwoFactorCode"></label>
                        <input class="form-input" asp-for="Input.TwoFactorCode" autocomplete="one-time-code" inputmode="numeric" placeholder="123456" />
                        <span asp-validation-for="Input.TwoFactorCode" class="text-danger"></span>
                    </div>

                    <label class="remember" asp-for="Input.RememberMachine">
                        <input asp-for="Input.RememberMachine" /> Trust this device for 30 days
                    </label>

                    <button class="btn btn-primary" type="submit">Verify and Continue</button>
                </form>

                <p class="auth-foot">Lost access to your second factor? <a asp-page="./ForgotPassword">Start account recovery</a></p>
            </div>
        </section>
    </main>

    <script src="~/js/auth.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
