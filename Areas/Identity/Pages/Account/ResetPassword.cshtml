@page
@model FinanceME.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceME</title>
    <link rel="icon" type="image/png" href="~/Logo/logo_transparent.png" />
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-page">
    <main class="auth-shell">
        <aside class="auth-brand">
            <div>
                <div class="auth-brand__masthead">
                    <a asp-controller="Home" asp-action="Index" class="auth-brand__logo" aria-label="FinanceME home">
                        <img src="~/Logo/logo_transparent.png" alt="FinanceME logo" />
                        <span class="auth-brand__wordmark">Finance<span>ME</span></span>
                    </a>
                    <span class="auth-kicker">Credential Reset</span>
                </div>
                <h1 class="auth-brand__title">Set a new <em>security key</em>.</h1>
            </div>
        </aside>

        <section class="auth-stage">
            <div class="auth-panel">
                <a asp-page="./ForgotPassword" class="auth-back-link" aria-label="Back to recovery request">
                    <span aria-hidden="true">&larr;</span>
                    Back to Recovery Request
                </a>

                <header class="auth-panel__head">
                    <h2 class="auth-panel__title">Reset Password</h2>
                    <p class="auth-panel__subtitle">Set your new password and continue.</p>
                </header>

                <form method="post" class="auth-form" novalidate>
                    <div asp-validation-summary="ModelOnly" class="auth-status error"></div>
                    <input asp-for="Input.Code" type="hidden" />

                    <div class="form-group">
                        <label class="form-label" asp-for="Input.Email"></label>
                        <input class="form-input" asp-for="Input.Email" autocomplete="email" placeholder="name@company.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Input.Password"></label>
                        <div class="auth-input-wrap">
                            <input class="form-input" asp-for="Input.Password" autocomplete="new-password" id="reset-password" data-password-strength placeholder="Create a secure password" />
                            <button type="button" class="auth-toggle-pass" data-toggle-password="reset-password" aria-label="Show new password" aria-pressed="false">Show</button>
                        </div>
                        <div class="auth-strength" aria-live="polite">
                            <div class="auth-strength__bar"><div class="auth-strength__fill"></div></div>
                            <p class="auth-strength__text">Add a stronger password</p>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Input.ConfirmPassword"></label>
                        <div class="auth-input-wrap">
                            <input class="form-input" asp-for="Input.ConfirmPassword" autocomplete="new-password" id="reset-password-confirm" placeholder="Repeat your new password" />
                            <button type="button" class="auth-toggle-pass" data-toggle-password="reset-password-confirm" aria-label="Show confirm password" aria-pressed="false">Show</button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button class="btn btn-primary" type="submit">Update Password</button>
                </form>

                <p class="auth-foot" style="margin-top: var(--space-lg)">Return to account access: <a asp-page="./Login">Log in</a></p>
            </div>
        </section>
    </main>

    <script src="~/js/auth.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
