@page
@{
    Layout = null;
    ViewData["Title"] = "Access Denied";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceME</title>
    <link rel="icon" type="image/png" href="~/Logo/logo_transparent.png" />
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-page">
    <main class="auth-shell">
        <aside class="auth-brand">
            <div>
                <div class="auth-brand__masthead">
                    <a asp-controller="Home" asp-action="Index" class="auth-brand__logo">
                        <img src="~/Logo/logo_transparent.png" alt="FinanceME logo" />
                        <span class="auth-brand__wordmark">Finance<span>ME</span></span>
                    </a>
                    <span class="auth-kicker">Authorization Guard</span>
                </div>
                <h1 class="auth-brand__title">Access <em>restricted</em>.</h1>
                <p class="auth-brand__copy">This action requires elevated permissions.</p>
            </div>
        </aside>

        <section class="auth-stage">
            <div class="auth-panel">
                <header class="auth-panel__head">
                    <h2 class="auth-panel__title">Access Denied</h2>
                    <p class="auth-panel__subtitle">Your account is signed in, but you are not authorized for this resource.</p>
                </header>
                <div class="auth-form">
                    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Back to Landing</a>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
