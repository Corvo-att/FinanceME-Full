@page
@model FinanceME.Areas.Identity.Pages.Account.ResendEmailConfirmationModel
@{
    Layout = null;
    ViewData["Title"] = "Resend Email Confirmation";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceME</title>
    <link rel="icon" type="image/png" href="~/Logo/logo_transparent.png" />
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-page">
    <main class="auth-shell">
        <aside class="auth-brand">
            <div>
                <div class="auth-brand__masthead">
                    <a asp-controller="Home" asp-action="Index" class="auth-brand__logo">
                        <img src="~/Logo/logo_transparent.png" alt="FinanceME logo" />
                        <span class="auth-brand__wordmark">Finance<span>ME</span></span>
                    </a>
                    <span class="auth-kicker">Email Verification</span>
                </div>
                <h1 class="auth-brand__title">Resend confirmation <em>securely</em>.</h1>
            </div>
        </aside>

        <section class="auth-stage">
            <div class="auth-panel">
                <header class="auth-panel__head">
                    <h2 class="auth-panel__title">Resend Email Confirmation</h2>
                    <p class="auth-panel__subtitle">Provide your account email and we will send a new confirmation link.</p>
                </header>

                <form method="post" class="auth-form" novalidate>
                    <div asp-validation-summary="ModelOnly" class="auth-status error"></div>
                    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                    {
                        <div class="auth-status success">@Model.StatusMessage</div>
                    }

                    <div class="form-group">
                        <label class="form-label" asp-for="Input.Email"></label>
                        <input class="form-input" asp-for="Input.Email" autocomplete="email" placeholder="name@company.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <button class="btn btn-primary" type="submit">Resend Confirmation</button>
                </form>
            </div>
        </section>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
