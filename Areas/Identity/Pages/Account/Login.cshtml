@page
@model FinanceME.Areas.Identity.Pages.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Log In";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceME</title>
    <link rel="icon" type="image/png" href="~/Logo/logo_transparent.png" />
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-page">
    <main class="auth-shell">
        <aside class="auth-brand" aria-label="FinanceME trust context">
            <div>
                <div class="auth-brand__masthead">
                    <a asp-controller="Home" asp-action="Index" class="auth-brand__logo" aria-label="FinanceME home">
                        <img src="~/Logo/logo_transparent.png" alt="FinanceME logo" />
                        <span class="auth-brand__wordmark">Finance<span>ME</span></span>
                    </a>
                    <span class="auth-kicker">Security Gateway</span>
                </div>
                <h1 class="auth-brand__title">Return to your <em>command deck</em>.</h1>
                <p class="auth-brand__copy">Access your live cash position, budget command rails, and risk alerts in one protected session.</p>
            </div>

            <div class="auth-proof-list">
                <div class="auth-proof-item">
                    <span class="label">Net Position</span>
                    <span class="value positive">+£112,891.12</span>
                </div>
                <div class="auth-proof-item">
                    <span class="label">Monthly Savings Rate</span>
                    <span class="value positive">+24.6%</span>
                </div>
                <div class="auth-proof-item">
                    <span class="label">Upcoming Bill</span>
                    <span class="value warning">Rent — £1,200 in 3 days</span>
                </div>
                <div class="auth-proof-item">
                    <span class="label">Budget Health</span>
                    <span class="value">87% — On Track</span>
                </div>
            </div>

            <p class="auth-brand__footnote">Protected by ASP.NET Core Identity &bull; AES-256 encryption &bull; Account lockout enabled</p>
        </aside>


        <section class="auth-stage">
            <div class="auth-panel">
                <a asp-controller="Home" asp-action="Index" class="auth-back-link" aria-label="Back to landing page">
                    <span aria-hidden="true">&larr;</span>
                    Back to Landing
                </a>

                <header class="auth-panel__head">
                    <h2 class="auth-panel__title">Log In</h2>
                    <p class="auth-panel__subtitle">Use your primary credentials to continue.</p>
                </header>

                <form method="post" class="auth-form" novalidate>
                    <input asp-for="ReturnUrl" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="auth-status error"></div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Input.Email"></label>
                        <input class="form-input" asp-for="Input.Email" autocomplete="email" placeholder="name@company.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Input.Password"></label>
                        <div class="auth-input-wrap">
                            <input class="form-input" asp-for="Input.Password" autocomplete="current-password" placeholder="Enter your password" id="login-password" />
                            <button type="button" class="auth-toggle-pass" data-toggle-password="login-password" aria-label="Show password" aria-pressed="false">Show</button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="auth-inline">
                        <label class="remember" asp-for="Input.RememberMe">
                            <input asp-for="Input.RememberMe" /> Keep me signed in for 30 days
                        </label>
                        <a class="auth-link" asp-page="./ForgotPassword">Forgot password?</a>
                    </div>

                    <button class="btn btn-primary" type="submit">Continue to Verification</button>
                </form>

                <p class="auth-foot">New to FinanceME? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create your account</a></p>
            </div>
        </section>
    </main>

    <script src="~/js/auth.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
