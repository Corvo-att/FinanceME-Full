@page
@model FinanceME.Areas.Identity.Pages.Account.RegisterConfirmationModel
@{
    Layout = null;
    ViewData["Title"] = "Registration Complete";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceME</title>
    <link rel="icon" type="image/png" href="~/Logo/logo_transparent.png" />
    <link rel="stylesheet" href="~/css/variables.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-page">
    <main class="auth-shell">
        <aside class="auth-brand" aria-label="FinanceME registration confirmation">
            <div>
                <div class="auth-brand__masthead">
                    <a asp-controller="Home" asp-action="Index" class="auth-brand__logo" aria-label="FinanceME home">
                        <img src="~/Logo/logo_transparent.png" alt="FinanceME logo" />
                        <span class="auth-brand__wordmark">Finance<span>ME</span></span>
                    </a>
                    <span class="auth-kicker">Account Created</span>
                </div>
                <h1 class="auth-brand__title">Welcome to your <em>financial cockpit</em>.</h1>
                <p class="auth-brand__copy">Your account has been created and is ready to use. Start by linking your first account or exploring the dashboard.</p>
            </div>

            <div class="auth-steps">
                <div class="auth-step">
                    <span class="index">01</span>
                    <span class="label">Account created ✓</span>
                </div>
                <div class="auth-step active">
                    <span class="index">02</span>
                    <span class="label">Confirm email</span>
                </div>
                <div class="auth-step">
                    <span class="index">03</span>
                    <span class="label">Access dashboard</span>
                </div>
            </div>

            <div class="auth-proof-list">
                <div class="auth-proof-item">
                    <span class="label">Account Status</span>
                    <span class="value positive">Active &amp; Secured</span>
                </div>
                <div class="auth-proof-item">
                    <span class="label">Next Step</span>
                    <span class="value">Check your email inbox</span>
                </div>
                <div class="auth-proof-item">
                    <span class="label">Data Encryption</span>
                    <span class="value positive">AES-256 · Enabled</span>
                </div>
            </div>

            <p class="auth-brand__footnote">No credit card required &bull; Cancel anytime &bull; 100% private</p>
        </aside>

        <section class="auth-stage">
            <div class="auth-panel">
                <header class="auth-panel__head" style="text-align:center;">
                    <div style="width:64px;height:64px;border-radius:50%;background:rgba(46,204,138,0.12);border:2px solid rgba(46,204,138,0.35);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;font-size:1.75rem;">
                        ✓
                    </div>
                    <h2 class="auth-panel__title">Registration Complete!</h2>
                    <p class="auth-panel__subtitle">
                        @if (Model.DisplayConfirmAccountLink)
                        {
                            <span>
                                Please confirm your email address. We sent a confirmation link to
                                <strong>@Model.Email</strong>.
                                Didn't get it?
                                <a class="auth-link" asp-page="./ResendEmailConfirmation">Resend confirmation email</a>.
                            </span>
                        }
                        else
                        {
                            <span>Your account is ready. You can now log in to FinanceME.</span>
                        }
                    </p>
                </header>

                @if (Model.DisplayConfirmAccountLink)
                {
                    <div style="background:rgba(26,26,36,0.6);border:1px solid var(--border-subtle);border-radius:var(--radius-md);padding:1rem 1.25rem;margin-bottom:1.5rem;">
                        <p style="font-size:0.82rem;color:var(--text-secondary);margin:0 0 0.5rem;">
                            <strong style="color:var(--text-primary);">Development mode:</strong> Email sending may not be configured.
                        </p>
                        <a href="@Model.EmailConfirmationUrl" class="auth-link" style="font-size:0.82rem;word-break:break-all;">
                            Click here to confirm your email account manually →
                        </a>
                    </div>
                }

                <div class="auth-form">
                    <a class="btn btn-primary" asp-page="./Login">
                        Continue to Login
                    </a>
                    <a class="btn btn-secondary" asp-controller="Home" asp-action="Index" style="width:100%;text-align:center;padding:0.7rem 1.5rem;">
                        Back to Home
                    </a>
                </div>

                <p class="auth-foot">
                    Having trouble?
                    <a asp-page="./ResendEmailConfirmation">Resend confirmation email</a>
                </p>
            </div>
        </section>
    </main>
</body>
</html>
