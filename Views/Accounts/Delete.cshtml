@model FinanceME.Models.Entities.Account

@{
    ViewData["Title"] = "Delete Account";
}

@section Styles {
    <link rel="stylesheet" href="~/css/transactions.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}

<div class="form-container">
    <header class="page-header">
        <a asp-action="Index" class="btn btn-ghost btn-sm" style="display: inline-flex; align-items: center; margin-bottom: var(--space-md); margin-left: -8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to Accounts
        </a>
    </header>

    <div class="card border-danger" style="padding: var(--space-xl); max-width: 600px; margin: 40px auto; border: 1px solid var(--danger);">
        <div style="text-align: center; margin-bottom: var(--space-lg);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-sm);">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <h2 class="text-display text-danger" style="font-size: 24px; margin-bottom: 8px;">Delete Account?</h2>
            <p class="text-secondary">Are you sure you want to deactivate this account? Your transaction history will be preserved.</p>
        </div>

        <div class="tx-hero" style="text-align: center; margin-bottom: var(--space-xl)">
            <div class="tx-amount @(Model?.Balance < 0 ? "amount-negative text-danger" : "amount-positive text-success")" style="font-size: 32px; font-weight: bold; font-family: var(--font-ui);">
                @Model?.Balance.ToString("C")
            </div>
            <div class="tx-merchant" style="font-size: 20px; font-weight: 500; display: inline-flex; align-items: center; margin-top: 8px;">
                @if (!string.IsNullOrEmpty(Model?.Color))
                {
                    <span style="background: @Model?.Color; width: 16px; height: 16px; border-radius: 50%; display: inline-block; margin-right: 8px;"></span>
                }
                @Model?.Name
            </div>
            <div class="tx-date text-secondary" style="margin-top: 4px;">@Model?.Institution @(!string.IsNullOrEmpty(Model?.AccountNumber) ? $"(...{Model.AccountNumber})" : "")</div>
        </div>

        <div style="margin-top: var(--space-xl);">
            <form asp-action="Delete" style="display: flex; gap: var(--space-sm);">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-ghost" style="flex: 1; justify-content: center; background-color: var(--surface-hover);">Cancel</a>
                <button type="submit" class="btn btn-danger" style="flex: 1; justify-content: center; background-color: var(--danger); color: white;">Deactivate Account</button>
            </form>
        </div>
    </div>
</div>