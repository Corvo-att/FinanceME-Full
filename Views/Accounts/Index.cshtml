@model IEnumerable<FinanceME.Models.Entities.Account>
@using FinanceME.Enums

@{
    ViewData["Title"] = "Accounts";
    var totalAssets      = Model.Where(a => a.Balance > 0).Sum(a => a.Balance);
    var totalLiabilities = Model.Where(a => a.Balance < 0).Sum(a => a.Balance);
    var netPosition      = totalAssets + totalLiabilities;
    var accountCount     = Model.Count();
}

@section Styles {
    <link rel="stylesheet" href="~/css/AccOver.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
    <style>
        /* ── Account flip cards ── */
        .accounts-flip-row {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: var(--space-md);
            padding: var(--space-md) 0;
        }
        .account-flip-card { perspective: 1000px; height: 170px; cursor: pointer; }
        .account-flip-inner {
            position: relative; width: 100%; height: 100%;
            transition: transform 0.55s cubic-bezier(0.23, 1, 0.32, 1);
            transform-style: preserve-3d;
        }
        .account-flip-card.is-flipped .account-flip-inner { transform: rotateY(180deg); }
        .card-face {
            position: absolute; inset: 0; border-radius: var(--radius-lg);
            backface-visibility: hidden; padding: var(--space-lg);
            border: 1px solid var(--border-subtle);
            display: flex; flex-direction: column; justify-content: space-between;
        }
        .card-front {
            background: linear-gradient(155deg, rgba(26,26,36,0.9), rgba(17,17,24,0.97));
        }
        .card-back {
            background: linear-gradient(155deg, rgba(30,26,18,0.95), rgba(17,17,24,0.97));
            transform: rotateY(180deg);
            justify-content: center; gap: var(--space-md);
        }
        .card-front-top { display: flex; justify-content: space-between; align-items: flex-start; }
        .card-icon {
            width: 38px; height: 38px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center; font-size: 18px;
        }
        .card-type-badge {
            font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px;
            padding: 3px 9px; border-radius: 20px;
            background: rgba(255,255,255,0.06); color: var(--text-secondary);
            border: 1px solid var(--border-subtle);
        }
        .card-name { font-weight: 700; font-size: 15px; color: var(--text-primary); margin-bottom: 2px; }
        .card-institution { font-size: 12px; color: var(--text-secondary); }
        .card-balance { font-family: var(--font-mono); font-size: 22px; font-weight: 600; }
        .card-balance.positive { color: var(--positive); }
        .card-balance.negative { color: var(--negative); }
        .card-back-action {
            display: flex; justify-content: space-between; gap: 8px;
        }
        .card-back-action a { flex: 1; text-align: center; }

        /* ── Empty state ── */
        .accounts-flip-empty {
            text-align: center; padding: 48px; color: var(--text-secondary); font-size: 14px;
        }

        /* ── Lower grid ── */
        .accounts-lower-grid {
            display: grid; grid-template-columns: 1fr minmax(280px, 340px);
            gap: var(--space-md); margin-top: var(--space-lg); align-items: start;
        }
        @@media (max-width: 1000px) { .accounts-lower-grid { grid-template-columns: 1fr; } }
    </style>
}

@* ── Toast ── *@
@if (TempData["SuccessMessage"] != null)
{
    <div id="acc-toast" style="position:fixed;bottom:24px;right:24px;z-index:500;background:var(--bg-elevated);border:1px solid rgba(46,204,138,0.3);border-radius:12px;padding:14px 20px;color:var(--text-primary);font-size:14px;font-weight:500;box-shadow:0 8px 32px rgba(0,0,0,0.5);">
        ✓ @TempData["SuccessMessage"]
    </div>
}

@* ══════════ HERO BANNER ══════════ *@
<div class="page-banner accounts-page-banner">
    <div class="page-banner-content">
        <div class="text-label" style="font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:var(--text-secondary);margin-bottom:6px;">ACCOUNTS &amp; BALANCES</div>
        <h1 class="accounts-hero-title" style="font-family:var(--font-display);margin:0 0 10px;">Accounts Command Center</h1>
        <p class="accounts-hero-subtitle">Track every linked and manual account in one place across bank, credit, investment, crypto, and cash.</p>
    </div>
    <div class="page-banner-actions accounts-banner-actions">
        <div class="accounts-action-group">
            <a asp-action="Create" class="btn btn-secondary">Add Manual Account</a>
            <button type="button" class="btn btn-primary" id="payment-toggle-btn">
                <span id="btn-txt">Link Bank Account</span>
            </button>
        </div>
    </div>
</div>

@* ══════════ KPI STAT CARDS ══════════ *@
<div class="grid grid-cols-4 accounts-kpi-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-md);margin-top:var(--space-lg);">
    <div class="stat-card">
        <div class="stat-card__label">Total Assets</div>
        <div class="stat-card__value" id="kpi-total-assets">@totalAssets.ToString("C")</div>
        <div class="stat-card__delta stat-card__delta--positive">All positive balances</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__label">Total Liabilities</div>
        <div class="stat-card__value amount-negative" id="kpi-total-liabilities" style="color:var(--negative);">@totalLiabilities.ToString("C")</div>
        <div class="stat-card__delta stat-card__delta--negative">All negative balances</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__label">Net Position</div>
        <div class="stat-card__value @(netPosition >= 0 ? "" : "amount-negative")" id="kpi-net-position" style="color:@(netPosition >= 0 ? "var(--positive)" : "var(--negative)");">@netPosition.ToString("C")</div>
        <div class="stat-card__delta @(netPosition >= 0 ? "stat-card__delta--positive" : "stat-card__delta--negative")">@(netPosition >= 0 ? "Healthy" : "In deficit")</div>
    </div>
    <div class="stat-card">
        <div class="stat-card__label">Linked Accounts</div>
        <div class="stat-card__value" id="kpi-linked-accounts">@accountCount</div>
        <div class="badge badge-neutral" style="width:fit-content;margin-top:8px;">@accountCount active</div>
    </div>
</div>

@* ══════════ ACCOUNTS OVERVIEW (tabs + flip cards) ══════════ *@
<div id="account-overview" class="stat-card" style="margin-top:var(--space-lg);">
    <div class="first section accounts-overview-header-row">
        <div class="accounts-overview-copy">
            <header id="accounts-header" class="text-section">Accounts Overview</header>
            <p class="accounts-overview-subtitle">Live balances grouped by account type. Hover a card to see actions.</p>
        </div>
        <div class="account-category-tabs-container">
            <input type="radio" id="tab-all"        name="acc-tabs" class="hidden-tab-input" checked />
            <label for="tab-all"        class="visual-tab-button" data-filter="all">All</label>
            <input type="radio" id="tab-checking"   name="acc-tabs" class="hidden-tab-input" />
            <label for="tab-checking"   class="visual-tab-button" data-filter="Checking">Checking</label>
            <input type="radio" id="tab-savings"    name="acc-tabs" class="hidden-tab-input" />
            <label for="tab-savings"    class="visual-tab-button" data-filter="Savings">Savings</label>
            <input type="radio" id="tab-credit"     name="acc-tabs" class="hidden-tab-input" />
            <label for="tab-credit"     class="visual-tab-button" data-filter="CreditCard">Credit</label>
            <input type="radio" id="tab-invest"     name="acc-tabs" class="hidden-tab-input" />
            <label for="tab-invest"     class="visual-tab-button" data-filter="Investment">Investment</label>
            <input type="radio" id="tab-cash"       name="acc-tabs" class="hidden-tab-input" />
            <label for="tab-cash"       class="visual-tab-button" data-filter="Cash">Cash</label>
        </div>
    </div>
    <hr class="accounts-divider" />

    @if (Model.Any())
    {
        <div id="accounts-flip-row" class="accounts-flip-row">
            @foreach (var acc in Model)
            {
                var color = !string.IsNullOrEmpty(acc.Color) ? acc.Color : "#C9A84C";
                var icon = acc.Type switch {
                    AccountType.Checking   => "fa-building-columns",
                    AccountType.Savings    => "fa-piggy-bank",
                    AccountType.CreditCard => "fa-credit-card",
                    AccountType.Investment => "fa-chart-line",
                    AccountType.Loan       => "fa-hand-holding-dollar",
                    AccountType.Cash       => "fa-money-bill-wave",
                    _                      => "fa-wallet"
                };
                <!-- CHANGE: added data-account-id so the JS transaction filter knows which account this card represents -->
                <div class="account-flip-card" data-type="@acc.Type.ToString()" data-balance="@acc.Balance" data-account-id="@acc.Id">
                    <div class="account-flip-inner">
                        <div class="card-face card-front">
                            <div class="card-front-top">
                                <div class="card-icon" style="background:@(color + "22"); color:@color;">
                                    <i class="fa-solid @icon"></i>
                                </div>
                                <span class="card-type-badge">@acc.Type</span>
                            </div>
                            <div style="margin-top: auto;">
                                <div class="card-name">@(string.IsNullOrEmpty(acc.Institution) ? "Manual Account" : acc.Institution)</div>
                                <div class="card-institution">@acc.Name@(!string.IsNullOrEmpty(acc.AccountNumber) ? $" ····{acc.AccountNumber}" : "")</div>
                                <div class="card-tap-hint" style="font-size: 11px; color: var(--text-secondary); opacity: 0.7; margin-top: 8px;">● Tap to see details</div>
                            </div>
                        </div>
                        <div class="card-face card-back">
                            <div class="card-back-top" style="display: flex; justify-content: space-between; font-size: 10px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">
                                <span>@(string.IsNullOrEmpty(acc.Institution) ? "Manual Account" : acc.Institution)</span>
                                <span>@acc.Type</span>
                            </div>
                            <div class="card-balance @(acc.Balance >= 0 ? "positive" : "negative")" style="text-align: center; margin-bottom: 16px;">
                                @acc.Balance.ToString("C")
                            </div>
                            <div class="card-back-action">
                                <a asp-action="Details" asp-route-id="@acc.Id" class="btn btn-ghost btn-sm">Details</a>
                                <a asp-action="Edit"    asp-route-id="@acc.Id" class="btn btn-ghost btn-sm">Edit</a>
                                <a asp-action="Delete"  asp-route-id="@acc.Id" class="btn btn-ghost btn-sm" style="color:var(--negative)">Remove</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <p id="accounts-flip-empty" class="accounts-flip-empty" style="display:none;">No accounts in this category yet.</p>
    }
    else
    {
        <div style="text-align:center;padding:64px 24px;">
            <div style="font-size:14px;font-weight:600;color:var(--text-primary);margin-bottom:8px;">No accounts yet</div>
            <p style="font-size:13px;color:var(--text-secondary);margin-bottom:20px;">Link a bank account or add a manual account to get started.</p>
            <a asp-action="Create" class="btn btn-primary">Add Account</a>
        </div>
    }
</div>

@* ══════════ LOWER GRID: Recent Activity + Quick Actions ══════════ *@
@{
    // CHANGE: Cast the ViewBag transactions for use in the view
    var recentTx = ViewBag.RecentTransactions as List<FinanceME.Models.Entities.Transaction>;
    recentTx ??= new List<FinanceME.Models.Entities.Transaction>();
}
<div class="accounts-lower-grid">
    @* Recent Activity — now shows real transactions filterable by flipped card *@
    <div id="Recent-activity" class="stat-card">
        <div class="recent-activity-header-row">
            <div>
                <header id="recent-activity-header" class="text-section">Recent Transactions</header>
                <p class="text-label" style="font-size:12px;color:var(--text-secondary);margin-top:4px;">
                    Flip a card above to filter by account. Showing latest @recentTx.Count transactions.
                </p>
            </div>
            <a asp-controller="Transactions" asp-action="Index" class="btn btn-ghost recent-activity-link">View all</a>
        </div>
        <table class="recent-activity-table">
            <thead>
                <tr>
                    <th class="text-label">Date</th>
                    <th class="text-label">Description</th>
                    <th class="text-label">Account</th>
                    <th class="text-label ra-col-right">Amount</th>
                </tr>
            </thead>
            <tbody id="recent-activity-tbody">
                @if (!recentTx.Any())
                {
                    <tr>
                        <td colspan="4" style="text-align:center;padding:32px 0;color:var(--text-secondary);font-size:13px;">No transactions yet.</td>
                    </tr>
                }
                @foreach (var tx in recentTx)
                {
                    // CHANGE: data-account-id links each row to its flip card for JS filtering
                    var isIncome = tx.Type == FinanceME.Enums.TransactionType.Income;
                    <tr class="recent-activity-details" data-account-id="@tx.AccountId">
                        <td class="ra-col institution-text" style="color:var(--text-secondary);font-size:12px;">@tx.Date.ToString("MMM dd")</td>
                        <td class="ra-col">
                            <span style="color:var(--text-primary);font-weight:500;">@tx.Description</span>
                            @if (tx.Category != null)
                            {
                                <br /><span style="font-size:11px;color:var(--text-secondary);">@tx.Category.Name</span>
                            }
                        </td>
                        <td class="ra-col institution-text" style="font-size:12px;">@tx.Account?.Name</td>
                        <td class="ra-col ra-col-right" style="font-family:var(--font-mono);color:@(isIncome ? "var(--positive)" : "var(--negative)");">
                            @(isIncome ? "+" : "-")EGP @tx.Amount.ToString("N2")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Quick Actions *@
    <aside class="stat-card quick-actions-card">
        <header class="text-section quick-actions-title">Quick Actions</header>
        <div class="quick-actions-list">
            <a asp-controller="Transactions" asp-action="Create" class="quick-action-item">
                <span>Add Transaction</span><span aria-hidden="true">&rarr;</span>
            </a>
            <a asp-action="Create" class="quick-action-item">
                <span>Add Account</span><span aria-hidden="true">&rarr;</span>
            </a>
            <a asp-controller="Transactions" asp-action="Index" class="quick-action-item">
                <span>View Transactions</span><span aria-hidden="true">&rarr;</span>
            </a>
            <a asp-controller="Categories" asp-action="Index" class="quick-action-item">
                <span>Manage Categories</span><span aria-hidden="true">&rarr;</span>
            </a>
        </div>
        <div class="quick-actions-sync card">
            <div class="text-label" style="font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--text-secondary);">Account Summary</div>
            <p class="quick-sync-time">@Model.Count() Active · @Model.Count(a => a.Balance < 0) Overdrawn</p>
            <p class="text-caption" style="color:var(--text-secondary);font-size:12px;">Balances update when you add or edit transactions.</p>
        </div>
    </aside>
</div>

@* ══════════ LINK BANK ACCOUNT MODAL ══════════ *@
<div class="payment-background" id="link-account-backdrop"></div>
<div id="paymentprompt" class="card link-bank-modal" role="dialog" aria-modal="true" aria-labelledby="link-account-title">
    <div class="link-bank-modal__header">
        <div>
            <p class="text-label" style="font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-secondary);">Secure Connection</p>
            <h2 id="link-account-title" class="text-section">Link Bank Account</h2>
        </div>
        <button type="button" id="payment-close-btn" class="close-btn" aria-label="Close">&times;</button>
    </div>
    <p class="link-bank-subtitle">Connect an account to keep balances, activity, and account health in sync with your Accounts Overview.</p>
    <div class="link-provider-row" role="group" aria-label="Supported providers">
        <button type="button" class="provider-tab active" data-provider="plaid">Plaid</button>
        <button type="button" class="provider-tab" data-provider="finicity">Finicity</button>
        <button type="button" class="provider-tab" data-provider="mx">MX</button>
        <button type="button" class="provider-tab" data-provider="manual">Manual Sync</button>
    </div>
    <div class="link-provider-copy" id="link-provider-copy" aria-live="polite">A secure redirect opens in a new window for sign in.</div>
    <form id="formcard" class="link-bank-form" method="POST" action="@Url.Action("Create", "Accounts")">
        @Html.AntiForgeryToken()
        <input type="hidden" id="link-provider-input" name="provider" value="plaid" />
        <div class="link-form-layout">
            <fieldset class="link-bank-fieldset">
                <legend class="sr-only">Account Details</legend>
                <div class="link-bank-grid">
                    <div class="field-group field-group--wide">
                        <label class="form-label" for="institution-name">Institution Name</label>
                        <input type="text" id="institution-name" class="form-input" name="Institution" placeholder="e.g. Chase Bank" autocomplete="organization" />
                    </div>
                    <div class="field-group">
                        <label class="form-label" for="account-modal-type">Account Type</label>
                        <select id="account-modal-type" class="form-input" name="Type" required>
                            <option value="" disabled selected>Select account type</option>
                            <option value="0">Checking</option>
                            <option value="1">Savings</option>
                            <option value="2">Credit Card</option>
                            <option value="3">Investment</option>
                            <option value="4">Loan</option>
                            <option value="5">Cash</option>
                            <option value="6">Other</option>
                        </select>
                    </div>
                    <div class="field-group">
                        <label class="form-label" for="account-modal-name">Account Nickname</label>
                        <input type="text" id="account-modal-name" class="form-input" name="Name" placeholder="Daily Spending" required />
                    </div>
                    <div class="field-group">
                        <label class="form-label" for="account-last4">Last 4 Digits</label>
                        <input type="text" id="account-last4" class="form-input" name="AccountNumber" placeholder="1234" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" />
                    </div>
                    <div class="field-group">
                        <label class="form-label" for="opening-balance">Opening Balance</label>
                        <input type="number" id="opening-balance" class="form-input" name="Balance" placeholder="0.00" step="0.01" value="0" required />
                    </div>
                    <div class="field-group">
                        <label class="form-label" for="currency-select">Currency</label>
                        <select id="currency-select" class="form-input" name="Currency">
                            <option value="EGP" selected>EGP</option>
                            <option value="USD">USD</option>
                            <option value="EUR">EUR</option>
                            <option value="GBP">GBP</option>
                        </select>
                    </div>
                </div>
            </fieldset>
            <aside class="link-preview-card" aria-label="Live account preview">
                <p class="text-label" style="font-size:11px;text-transform:uppercase;color:var(--text-secondary);">Preview</p>
                <h3 class="link-preview-title" id="preview-name">New Institution</h3>
                <p class="link-preview-type" id="preview-type">Select account type</p>
                <div class="link-preview-row">
                    <span class="text-caption">Ending</span>
                    <strong id="preview-last4">••••</strong>
                </div>
                <div class="link-preview-row">
                    <span class="text-caption">Starting Balance</span>
                    <strong id="preview-balance">EGP 0.00</strong>
                </div>
                <div class="link-preview-row">
                    <span class="text-caption">Provider</span>
                    <strong id="preview-provider">Plaid</strong>
                </div>
            </aside>
        </div>
        <label class="link-consent-row" for="sync-consent">
            <input type="checkbox" id="sync-consent" required />
            <span>I authorize read-only sync for balances and transactions.</span>
        </label>
        <div class="link-bank-actions">
            <button type="button" id="payment-cancel-btn" class="btn btn-secondary">Cancel</button>
            <button type="submit" id="paybtn" class="btn btn-primary">Link Account</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function(){
    // ── Modal open/close ──
    const backdrop   = document.getElementById('link-account-backdrop');
    const modal      = document.getElementById('paymentprompt');
    const openBtn    = document.getElementById('payment-toggle-btn');
    const closeBtn   = document.getElementById('payment-close-btn');
    const cancelBtn  = document.getElementById('payment-cancel-btn');

    function openModal()  { 
        if (backdrop && backdrop.parentNode !== document.body) document.body.appendChild(backdrop);
        if (modal && modal.parentNode !== document.body) document.body.appendChild(modal);
        modal.style.display = 'block'; 
        backdrop.style.display = 'block'; 
        document.body.style.overflow = 'hidden'; 
    }
    function closeModal() { modal.style.display = 'none';  backdrop.style.display = 'none';  document.body.style.overflow = ''; }

    if (openBtn)  openBtn.addEventListener('click', openModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (cancelBtn)cancelBtn.addEventListener('click', closeModal);
    if (backdrop) backdrop.addEventListener('click', closeModal);

    // ── Provider tabs ──
    const providerCopy = { plaid: 'A secure redirect opens in a new window for sign in.', finicity: 'Finicity opens a secure OAuth flow to connect your accounts.', mx: 'MX uses bank-grade encryption to link your account.', manual: 'Enter your account details manually without connecting to a bank.' };
    document.querySelectorAll('.provider-tab').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.provider-tab').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            const p = this.dataset.provider;
            document.getElementById('link-provider-input').value = p;
            document.getElementById('link-provider-copy').textContent = providerCopy[p] || '';
            document.getElementById('preview-provider').textContent = this.textContent;
        });
    });

    // ── Live preview ──
    const nameInput    = document.getElementById('institution-name');
    const typeSelect   = document.getElementById('account-modal-type');
    const last4Input   = document.getElementById('account-last4');
    const balanceInput = document.getElementById('opening-balance');
    const typeLabels   = ['Checking','Savings','Credit Card','Investment','Crypto Wallet','Cash / Other'];

    function updatePreview() {
        const n = nameInput?.value.trim() || 'New Institution';
        const t = typeSelect?.value !== '' ? typeLabels[parseInt(typeSelect.value)] || 'Select account type' : 'Select account type';
        const l = last4Input?.value.trim() || '••••';
        const b = parseFloat(balanceInput?.value) || 0;
        document.getElementById('preview-name').textContent    = n;
        document.getElementById('preview-type').textContent    = t;
        document.getElementById('preview-last4').textContent   = l;
        document.getElementById('preview-balance').textContent = 'EGP ' + b.toFixed(2);
    }
    [nameInput, typeSelect, last4Input, balanceInput].forEach(el => { if(el) el.addEventListener('input', updatePreview); });

    // ── Account type tab filtering ──
    document.querySelectorAll('.visual-tab-button').forEach(lbl => {
        lbl.addEventListener('click', function() {
            const filter = this.dataset.filter || 'all';
            const cards = document.querySelectorAll('.account-flip-card');
            let visible = 0;
            cards.forEach(card => {
                const show = filter === 'all' || card.dataset.type === filter;
                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            const empty = document.getElementById('accounts-flip-empty');
            if (empty) empty.style.display = visible === 0 ? '' : 'none';
        });
    });

    // ── Auto-dismiss toast ──
    const toast = document.getElementById('acc-toast');
    if (toast) setTimeout(() => toast.style.opacity = '0', 4000);

    // ── Toggle Flip and KPI Recalculation ──
    function formatCurrency(amount) {
        const isNegative = amount < 0;
        const absAmount = Math.abs(amount);
        const formatted = absAmount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        return (isNegative ? '-E£' : 'E£') + formatted;
    }

    function updateKPIs() {
        const allCards = document.querySelectorAll('.account-flip-card');
        const flippedCards = document.querySelectorAll('.account-flip-card.is-flipped');
        
        // If none flipped, calculate total of all
        const activeCards = flippedCards.length > 0 ? flippedCards : allCards;
        
        let totalAssets = 0;
        let totalLiabilities = 0;
        let accountCount = activeCards.length;
        
        activeCards.forEach(card => {
            const balance = parseFloat(card.dataset.balance) || 0;
            if (balance > 0) {
                totalAssets += balance;
            } else {
                totalLiabilities += balance;
            }
        });
        
        const netPosition = totalAssets + totalLiabilities;
        
        const kpiAssets = document.getElementById('kpi-total-assets');
        if(kpiAssets) kpiAssets.textContent = formatCurrency(totalAssets);
        
        const kpiLiab = document.getElementById('kpi-total-liabilities');
        if(kpiLiab) kpiLiab.textContent = formatCurrency(totalLiabilities);
        
        const kpiNet = document.getElementById('kpi-net-position');
        if(kpiNet) {
            kpiNet.textContent = formatCurrency(netPosition);
            kpiNet.style.color = netPosition >= 0 ? 'var(--positive)' : 'var(--negative)';
            kpiNet.classList.toggle('amount-negative', netPosition < 0);
        }
        
        const kpiLinked = document.getElementById('kpi-linked-accounts');
        if(kpiLinked) kpiLinked.textContent = accountCount;
    }

    // CHANGE: Filter the transaction table rows by flipped card account IDs
    function updateTransactionTable() {
        const flipped = document.querySelectorAll('.account-flip-card.is-flipped');
        const rows = document.querySelectorAll('#recent-activity-tbody tr[data-account-id]');
        if (flipped.length === 0) {
            // Nothing flipped — show all
            rows.forEach(r => r.style.display = '');
        } else {
            const filterIds = new Set([...flipped].map(c => c.dataset.accountId));
            rows.forEach(r => {
                r.style.display = filterIds.has(r.dataset.accountId) ? '' : 'none';
            });
        }
    }

    document.querySelectorAll('.account-flip-card').forEach(card => {
        card.addEventListener('click', function(e) {
            // Prevent flipping if clicking an action button on the back
            if (e.target.closest('a') || e.target.closest('button')) return;
            
            this.classList.toggle('is-flipped');
            updateKPIs();
            updateTransactionTable(); // CHANGE: also filter transactions on flip
        });
    });
})();
</script>
}