@model FinanceME.Models.ViewModels.AccountSummaryViewModel
@using FinanceME.Enums

@{
    ViewData["Title"] = "Account Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/transactions.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}

<div class="form-container">
    <header class="page-header">
        <a asp-action="Index" class="btn btn-ghost btn-sm" style="display: inline-flex; align-items: center; margin-bottom: var(--space-md); margin-left: -8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to Accounts
        </a>
    </header>

    <div class="card" style="padding: var(--space-xl); margin: 40px auto;">
        <div class="tx-hero" style="text-align: center; margin-bottom: var(--space-xl)">
            <div class="tx-amount @(Model?.Account?.Balance < 0 ? "amount-negative text-danger" : "amount-positive text-success")" style="font-size: 32px; font-weight: bold; font-family: var(--font-ui);">
                @Model?.Account?.Balance.ToString("C")
            </div>
            <div class="tx-merchant" style="font-size: 20px; font-weight: 500; display: inline-flex; align-items: center; margin-top: 8px;">
                @if (!string.IsNullOrEmpty(Model?.Account?.Color))
                {
                    <span style="background: @Model?.Account?.Color; width: 16px; height: 16px; border-radius: 50%; display: inline-block; margin-right: 8px;"></span>
                }
                @Model?.Account?.Name
            </div>
            <div class="tx-date text-secondary" style="margin-top: 4px;">@Model?.Account?.Institution @(!string.IsNullOrEmpty(Model?.Account?.AccountNumber) ? $"(...{Model.Account.AccountNumber})" : "")</div>
            <div class="tx-date text-secondary" style="margin-top: 4px;">Currency: @Model?.Account?.Currency | Type: @Model?.Account?.Type</div>
        </div>

        <div class="detail-list" style="display: flex; flex-direction: column; gap: var(--space-md); margin-bottom: var(--space-xl);">
            <div class="detail-row" style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: var(--space-sm);">
                <span class="detail-label text-secondary">Total Income</span>
                <span class="detail-value text-success" style="font-weight: 500;">+@Model?.TotalIncome.ToString("C")</span>
            </div>
            <div class="detail-row" style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: var(--space-sm);">
                <span class="detail-label text-secondary">Total Expense</span>
                <span class="detail-value text-danger" style="font-weight: 500;">-@Model?.TotalExpense.ToString("C")</span>
            </div>
            <div class="detail-row" style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: var(--space-sm);">
                <span class="detail-label text-secondary">Total Transactions</span>
                <span class="detail-value" style="font-weight: 500;">@Model?.TransactionCount</span>
            </div>
        </div>

        <div style="display: flex; gap: var(--space-sm); justify-content: center; margin-bottom: var(--space-xl);">
            <a asp-action="Edit" asp-route-id="@Model?.Account?.Id" class="btn btn-primary" style="flex: 1; justify-content: center; max-width: 250px;">Edit Account</a>
            <a asp-action="Delete" asp-route-id="@Model?.Account?.Id" class="btn btn-ghost text-danger" style="flex: 1; justify-content: center; max-width: 250px; background-color: var(--surface-hover);">Delete</a>
        </div>

        <h3 class="text-display" style="font-size: 20px; margin-bottom: var(--space-md);">Recent Transactions</h3>
        
        <table class="data-table" style="width: 100%;">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Category</th>
                    <th class="col-amount" style="text-align: right">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model?.RecentTransactions ?? new List<FinanceME.Models.Entities.Transaction>())
                {
                    <tr>
                        <td class="text-caption">@item.Date.ToString("MMM dd, yyyy")</td>
                        <td style="font-weight: 500">@item.Description</td>
                        <td>
                            @if(item.Category != null)
                            {
                                @if (!string.IsNullOrEmpty(item.Category.Color))
                                {
                                    <span class="category-dot" style="background: @item.Category.Color; display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 8px;"></span>
                                }
                                else
                                {
                                    <span class="category-dot" style="background: var(--text-muted); display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 8px;"></span>
                                }
                                @item.Category.Name
                            }
                            else
                            {
                                <span class="category-dot" style="background: var(--text-muted); display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 8px;"></span>
                                <text>Uncategorized</text>
                            }
                        </td>
                        <td class="col-amount data-figure-sm @(item.Type == TransactionType.Expense ? "amount-negative text-danger" : "amount-positive text-success")" style="text-align: right">
                            @if(item.Type == TransactionType.Expense)
                            {
                                <text> -@item.Amount.ToString("C") </text>
                            }
                            else
                            {
                                <text> +@item.Amount.ToString("C") </text>
                            }
                        </td>
                    </tr>
                }
                @if(!Model.RecentTransactions.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted" style="padding: var(--space-xl) 0;">No recent transactions in this account.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>