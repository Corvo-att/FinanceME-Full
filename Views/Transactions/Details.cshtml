@model FinanceME.Models.Entities.Transaction
@using FinanceME.Enums

@{
    ViewData["Title"] = "Transaction Details";
}

@section Styles {
    <style>
        .tx-details-card {
            max-width: 500px; margin: 40px auto;
            background: var(--bg-surface); border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg); padding: 40px;
        }
        .tx-d-hero { text-align: center; margin-bottom: 40px; }
        .tx-d-amount {
            font-size: 42px; font-weight: 700; font-family: var(--font-mono); margin-bottom: 8px;
        }
        .tx-d-amount.negative { color: var(--negative); }
        .tx-d-amount.positive { color: var(--positive); }
        .tx-d-merchant { font-size: 20px; font-weight: 600; font-family: "Georgia", serif; color: var(--text-primary); margin-bottom: 6px; }
        .tx-d-date { font-size: 13px; color: var(--text-secondary); }

        .tx-d-list { display: flex; flex-direction: column; }
        .tx-d-row {
            display: flex; justify-content: space-between; align-items: flex-start;
            padding: 20px 0; border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .tx-d-row:last-child { border-bottom: none; }
        .tx-d-label { font-size: 11px; letter-spacing: 1.2px; text-transform: uppercase; color: var(--text-secondary); font-weight: 600; flex-shrink: 0; width: 140px; }
        .tx-d-val { font-size: 14px; font-weight: 500; color: var(--text-primary); text-align: right; }
        .tx-d-val.notes { text-align: right; color: var(--text-secondary); line-height: 1.5; }

        .status-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--positive); margin-right: 8px; }

        .tx-d-footer {
            display: flex; justify-content: space-between; align-items: center;
            margin-top: 40px; padding-top: 0;
        }
        .btn-delete-outline {
            background: transparent; border: 1px solid rgba(224,92,92,0.3); color: var(--negative);
            padding: 10px 24px; border-radius: 6px; font-weight: 500; font-size: 14px;
            display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
            transition: all 0.2s ease;
        }
        .btn-delete-outline:hover { background: rgba(224,92,92,0.1); border-color: var(--negative); color: var(--negative); }

        .btn-edit-solid {
            background: var(--accent-gold); color: #000; border: none;
            padding: 10px 32px; border-radius: 6px; font-weight: 600; font-size: 14px;
            display: inline-flex; align-items: center; gap: 8px; text-decoration: none;
        }
    </style>
}

<div class="tx-details-card">
    <div class="tx-d-hero">
        <div class="tx-d-amount @(Model?.Type == TransactionType.Expense ? "negative" : Model?.Type == TransactionType.Income ? "positive" : "")">
            @(Model?.Type == TransactionType.Expense ? "-" : Model?.Type == TransactionType.Income ? "+" : "")@Model?.Amount.ToString("C")
        </div>
        <div class="tx-d-merchant">@Model?.Description</div>
        <div class="tx-d-date">@Model?.Date.ToString("MMMM dd, yyyy 'at' h:mm tt")</div>
    </div>

    <div class="tx-d-list">
        <div class="tx-d-row">
            <div class="tx-d-label">STATUS</div>
            <div class="tx-d-val"><span class="status-dot"></span>Settled</div>
        </div>
        <div class="tx-d-row">
            <div class="tx-d-label">CATEGORY</div>
            <div class="tx-d-val"><span class="status-dot" style="background: @(Model?.Category?.Color ?? "var(--positive)");"></span>@(Model?.Category?.Name ?? "Uncategorized")</div>
        </div>
        <div class="tx-d-row">
            <div class="tx-d-label">ACCOUNT</div>
            <div class="tx-d-val">@Model?.Account?.Name</div>
        </div>
        @if (Model?.Type == TransactionType.Transfer)
        {
            <div class="tx-d-row">
                <div class="tx-d-label">TRANSFERRED TO</div>
                <div class="tx-d-val">@Model?.TransferToAccount?.Name</div>
            </div>
        }
        <div class="tx-d-row">
            <div class="tx-d-label">TRANSACTION ID</div>
            <div class="tx-d-val" style="font-family: var(--font-mono); font-size: 13px;">TXN-@(Model?.Id.ToString().PadLeft(8, '0') + "A")</div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model?.Notes))
        {
            <div class="tx-d-row">
                <div class="tx-d-label">NOTES</div>
                <div class="tx-d-val notes">@Model?.Notes</div>
            </div>
        }
    </div>

    <div class="tx-d-footer">
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn-delete-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            Delete
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-edit-solid">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            Edit
        </a>
    </div>
</div>
