@model FinanceME.Models.Entities.Budget 
@using FinanceME.Models.Entities

@{
    ViewData["Title"] = "Budget detail Overview";
    var transactions = ViewBag.Transactions as List<Transaction>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/budgets.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}


<body>
    <div class="app-container">
        <div id="sidebar-container"></div>
        <div class="sidebar-overlay" id="sidebar-overlay"></div>

        <div class="main-content">
            <div id="header-container"></div>

            <div class="content-wrapper">
                <header class="page-header">
                <a asp-controller="Budgets" asp-action="Index" class="btn btn-ghost btn-sm" title="Budgets"
                       class="btn btn-ghost btn-sm"
                       style="
                display: inline-flex;
                align-items: center;
                margin-left: -8px;
              ">
                        <svg width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             style="margin-right: 4px">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                        Back to Budgets
                    </a>

                    <div style="display: flex; gap: var(--space-sm)">
                    
                    <div class="actions-group" style="display: flex; gap: var(--space-sm); margin-top: var(--space-md)">
                        <a asp-controller="Budgets"
                           asp-action="Editbudget"
                           asp-route-id="@Model.Id"
                           class="btn btn-secondary">
                            Edit Budget
                        </a>

                        <form asp-controller="Budgets" asp-action="DeleteBudget" asp-route-id="@Model.Id" method="post">
                            <button type="submit"
                                    class="btn btn-ghost"
                                    style="color: var(--negative)">
                                Delete
                            </button>
                        </form>
                    </div>

                    </div>

                </header>

                <div class="budget-hero">
                    <div class="hero-top">
                        <div class="hero-title-group">
                            <div class="budget-icon">
                                <svg width="24"
                                     height="24"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2"
                                     stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
                                    <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
                                    <line x1="6" y1="1" x2="6" y2="4"></line>
                                    <line x1="10" y1="1" x2="10" y2="4"></line>
                                    <line x1="14" y1="1" x2="14" y2="4"></line>
                                </svg>
                            </div>
                            <div>
                                <h1 class="text-display" style="font-size: 24px">
                                    @Model.Category.Name
                                </h1>
                                <span style="
                      color: var(--text-secondary);
                      font-size: 13px;
                      text-transform: uppercase;
                      letter-spacing: 1px;
                    ">@Model.Category.CreatedAt</span>
                            </div>
                        </div>
                    </div>

                    @{
                        decimal sum = 0;


                        foreach (var item in transactions)
                        {
                            sum += item.Amount;
                        }

                        Model.SpentAmount = Model.LimitAmount - sum;

                    <div class="budget-amount-display">
                       
                           

                          

                            <span class="hero-spent">EGP @sum</span>
                       

                    <span class="hero-total">OF EGP @Model.LimitAmount limit</span>
                    </div>

                    <div class="progress-container">
                        <div class="progress-meta">
                            <span class="text-warning">84% used</span>
                            <span>EGP @Model.SpentAmount left</span>
                        </div>
                        
                        <div class="progress-track">
                            <div class="progress-fill" style="width: 84%"></div>
                        </div>
                        
                    </div>
                    }

                    <div class="insight-box">
                        <svg width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="var(--warning)"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        <span class="insight-text">
                            You've spent more rapidly than usual. At this rate, you will
                            exceed your budget in <strong>4 days.</strong>
                        </span>
                    </div>
                </div>

                <h2 class="text-display"
                    style="font-size: 18px; margin-bottom: var(--space-md)">
                    Recent Transactions
                </h2>

                <div class="card" style="padding: 0; overflow: hidden">
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Merchant</th>
                                    <th>Subcategory</th>
                                    <th style="text-align: right">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var i = 0;

                                    foreach (var item in transactions)
                                    {
                                        var subCategory = item.Category?.SubCategories
                                        .ElementAtOrDefault(i);

                                        i++;

                                        <tr>
                                            <td>@item.CreatedAt</td>
                                            <td>
                                                <span style="color: var(--text-primary); font-weight: 500">@item.Description</span>
                                            </td>
                                            <td>@(subCategory?.Name ?? "No Subcategory")</td>
                                            <td style="text-align: right; font-family: var(--font-mono)">
                                                EGP @item.Amount
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div style="
                padding: var(--space-sm);
                text-align: center;
                border-top: 1px solid var(--border-subtle);
                background: var(--bg-surface);
              ">
                        <a asp-controller="Transactions" asp-action="Index" class="btn btn-ghost btn-sm">View All in @Model.Category.Name</a>
                    </div>
                </div>
            </div>

            <div id="footer-container"></div>
        </div>
    </div>
</body>

@section Scripts {
    <script>
        window.ACTIVE_PAGE = "budgetdetail";
        window.USER_NAME = "@(User.Identity?.Name ?? "User")";
    </script>
    <script src="~/js/utils.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/budgets.js" asp-append-version="true"></script>
}

   
