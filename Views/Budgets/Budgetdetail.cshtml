@{
    ViewData["Title"] = "Budget detail Overview";
}

@section Styles {
    <link rel="stylesheet" href="~/css/budgets.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}



    <div class="app-container">
        <div id="sidebar-container"></div>
        <div class="sidebar-overlay" id="sidebar-overlay"></div>

        <div class="main-content">
            <div id="header-container"></div>

            <div class="content-wrapper">
                <header class="page-header">
                <a asp-controller="Budgets" asp-action="Index" class="btn btn-ghost btn-sm" title="Budgets"
                       class="btn btn-ghost btn-sm"
                       style="
                display: inline-flex;
                align-items: center;
                margin-left: -8px;
              ">
                        <svg width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             style="margin-right: 4px">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                        Back to Budgets
                    </a>

                    <div style="display: flex; gap: var(--space-sm)">
                    <a asp-controller="Budgets" asp-action="Createbudget" class="btn btn-secondary" title="Budgets">Edit Budget</a>
                        <button class="btn btn-ghost" style="color: var(--negative)">
                            Delete
                        </button>
                    </div>
                </header>

                <div class="budget-hero">
                    <div class="hero-top">
                        <div class="hero-title-group">
                            <div class="budget-icon">
                                <svg width="24"
                                     height="24"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2"
                                     stroke-linecap="round"
                                     stroke-linejoin="round">
                                    <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
                                    <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
                                    <line x1="6" y1="1" x2="6" y2="4"></line>
                                    <line x1="10" y1="1" x2="10" y2="4"></line>
                                    <line x1="14" y1="1" x2="14" y2="4"></line>
                                </svg>
                            </div>
                            <div>
                                <h1 class="text-display" style="font-size: 24px">
                                    Food & Dining
                                </h1>
                                <span style="
                      color: var(--text-secondary);
                      font-size: 13px;
                      text-transform: uppercase;
                      letter-spacing: 1px;
                    ">March 2026</span>
                            </div>
                        </div>
                    </div>

                    <div class="budget-amount-display">
                        <span class="hero-spent">EGP 420.50</span>
                        <span class="hero-total">of EGP 500.00 limits</span>
                    </div>

                    <div class="progress-container">
                        <div class="progress-meta">
                            <span class="text-warning">84% used</span>
                            <span>EGP 79.50 left</span>
                        </div>
                        <div class="progress-track">
                            <div class="progress-fill" style="width: 84%"></div>
                        </div>
                    </div>

                    <div class="insight-box">
                        <svg width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="var(--warning)"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        <span class="insight-text">
                            You've spent more rapidly than usual. At this rate, you will
                            exceed your budget in <strong>4 days.</strong>
                        </span>
                    </div>
                </div>

                <h2 class="text-display"
                    style="font-size: 18px; margin-bottom: var(--space-md)">
                    Recent Transactions
                </h2>

                <div class="card" style="padding: 0; overflow: hidden">
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Merchant</th>
                                    <th>Subcategory</th>
                                    <th style="text-align: right">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Mar 14, 2026</td>
                                    <td>
                                        <span style="color: var(--text-primary); font-weight: 500">Whole Foods Market</span>
                                    </td>
                                    <td>Groceries</td>
                                    <td style="text-align: right; font-family: var(--font-mono)">
                                        EGP 112.40
                                    </td>
                                </tr>
                                <tr>
                                    <td>Mar 12, 2026</td>
                                    <td>
                                        <span style="color: var(--text-primary); font-weight: 500">Uber Eats</span>
                                    </td>
                                    <td>Delivery</td>
                                    <td style="text-align: right; font-family: var(--font-mono)">
                                        EGP 45.90
                                    </td>
                                </tr>
                                <tr>
                                    <td>Mar 10, 2026</td>
                                    <td>
                                        <span style="color: var(--text-primary); font-weight: 500">Starbucks</span>
                                    </td>
                                    <td>Coffee</td>
                                    <td style="text-align: right; font-family: var(--font-mono)">
                                        EGP 6.50
                                    </td>
                                </tr>
                                <tr>
                                    <td>Mar 05, 2026</td>
                                    <td>
                                        <span style="color: var(--text-primary); font-weight: 500">Trader Joe's</span>
                                    </td>
                                    <td>Groceries</td>
                                    <td style="text-align: right; font-family: var(--font-mono)">
                                        EGP 89.20
                                    </td>
                                </tr>
                                <tr>
                                    <td>Mar 02, 2026</td>
                                    <td>
                                        <span style="color: var(--text-primary); font-weight: 500">DoorDash</span>
                                    </td>
                                    <td>Delivery</td>
                                    <td style="text-align: right; font-family: var(--font-mono)">
                                        EGP 32.10
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div style="
                padding: var(--space-sm);
                text-align: center;
                border-top: 1px solid var(--border-subtle);
                background: var(--bg-surface);
              ">
                        <a href="transactions.html" class="btn btn-ghost btn-sm">View All in Food & Dining</a>
                    </div>
                </div>
            </div>

            <div id="footer-container"></div>
        </div>
    </div>

@section Scripts {
    <script>
        window.ACTIVE_PAGE = "budgets";
        window.USER_NAME = "@(User.Identity?.Name ?? "User")";
    </script>
    <script src="~/js/utils.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/budgets.js" asp-append-version="true"></script>
}

   
