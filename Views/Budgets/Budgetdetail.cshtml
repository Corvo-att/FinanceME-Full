@model FinanceME.Models.Entities.Budget
@using FinanceME.Models.Entities

@{
    ViewData["Title"] = "Budget detail Overview";
    var transactions = ViewBag.Transactions as List<Transaction>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/budgets.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}

                <header class="page-header">
                    <a asp-controller="Budgets" asp-action="Index" class="btn btn-ghost btn-sm" title="Budgets"
                       class="btn btn-ghost btn-sm"
                       style="
                display: inline-flex;
                align-items: center;
                margin-left: -8px;
              ">
                        <svg width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round"
                             style="margin-right: 4px">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                        Back to Budgets
                    </a>

                    <div style="display: flex; gap: var(--space-sm)">

                        <div class="actions-group" style="display: flex; gap: var(--space-sm); margin-top: var(--space-md)">
                            <a asp-controller="Budgets"
                               asp-action="Editbudget"
                               asp-route-id="@Model.Id"
                               class="btn btn-secondary">
                                Edit Budget
                            </a>

                            <form asp-controller="Budgets" asp-action="DeleteBudget" asp-route-id="@Model.Id" method="post">
                                <button type="submit"
                                        class="btn btn-ghost"
                                        style="color: var(--negative)">
                                    Delete
                                </button>
                            </form>
                        </div>

                    </div>

                </header>

                <div class="budget-hero">
                    <div class="hero-top">
                        <div class="hero-title-group">
                            <div class="budget-icon">
                                @* CHANGE: Use category emoji icon if available, SVG fallback otherwise *@
                                @if (!string.IsNullOrEmpty(Model.Category?.Icon))
                                {
                                    <span style="font-size: 24px">@Model.Category.Icon</span>
                                }
                                else
                                {
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"></path>
                                        <path d="M3 5v14a2 2 0 0 0 2 2h16v-5"></path>
                                        <path d="M18 12a2 2 0 0 0 0 4h4v-4z"></path>
                                    </svg>
                                }
                            </div>
                            <div>
                                <h1 class="text-display" style="font-size: 24px">
                                    @Model.Category.Name
                                </h1>
                                <span style="
                      color: var(--text-secondary);
                      font-size: 13px;
                      letter-spacing: 1px;
                    ">@Model.CreatedAt.ToString("MMM yyyy")</span>
                            </div>
                        </div>
                    </div>

                    @{
                        decimal sum = 0;

                        foreach (var item in transactions)
                        {
                            sum += item.Amount;
                        }

                        // FIX: SpentAmount = total of matching transactions, Remaining = limit - spent
                        decimal spent = sum;
                        decimal remaining = Model.LimitAmount - spent;
                        decimal pct = Model.LimitAmount > 0 ? Math.Round((spent / Model.LimitAmount) * 100, 0) : 0;
                        string statusClass = pct < 60 ? "text-safe" : pct < 85 ? "text-warning" : "text-danger";
                        string fillClass = pct < 60 ? "fill-safe" : pct < 85 ? "fill-warning" : "fill-danger";

                        <div class="budget-amount-display">
                            <span class="hero-spent">EGP @spent.ToString("N2")</span>
                            <span class="hero-total">OF EGP @Model.LimitAmount.ToString("N2") limit</span>
                        </div>

                        <div class="progress-container">
                            <div class="progress-meta">
                                <span class="@statusClass">@pct% used</span>
                                <span>EGP @remaining.ToString("N2") left</span>
                            </div>

                            <div class="progress-track">
                                <div class="progress-fill @fillClass" style="width: @pct%"></div>
                            </div>
                        </div>
                    }

                    @* CHANGE: Only show warning insight-box when alert is enabled AND threshold breached *@
                    @if (Model.AlertOnThreshold && pct >= (decimal)Model.WarningThreshold)
                    {
                        <div class="insight-box">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="var(--warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="12" y1="8" x2="12" y2="12"></line>
                                <line x1="12" y1="16" x2="12.01" y2="16"></line>
                            </svg>
                            <span class="insight-text">
                                ⚠️ You've reached <strong>@pct%</strong> of your <strong>EGP @Model.LimitAmount.ToString("N2")</strong> budget.
                                @if (remaining > 0)
                                {
                                    <text>Only <strong>EGP @remaining.ToString("N2")</strong> remaining.</text>
                                }
                                else
                                {
                                    <text>You are <strong>EGP @(Math.Abs(remaining).ToString("N2"))</strong> over budget!</text>
                                }
                            </span>
                        </div>
                    }
                </div>

                <h2 class="text-display"
                    style="font-size: 18px; margin-bottom: var(--space-md)">
                    Recent Transactions
                </h2>

                <div class="card" style="padding: 0; overflow: hidden">
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Merchant</th>
                                    <th>Subcategory</th>
                                    <th style="text-align: right">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var i = 0;

                                    foreach (var item in transactions)
                                    {
                                        var subCategory = item.Category?.SubCategories
                                        .ElementAtOrDefault(i);

                                        i++;

                                        <tr>
                                            <td>@item.CreatedAt</td>
                                            <td>
                                                <span style="color: var(--text-primary); font-weight: 500">@item.Description</span>
                                            </td>
                                            <td>@(subCategory?.Name ?? "No Subcategory")</td>
                                            <td style="text-align: right; font-family: var(--font-mono)">
                                                EGP @item.Amount
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div style="
                padding: var(--space-sm);
                text-align: center;
                border-top: 1px solid var(--border-subtle);
                background: var(--bg-surface);
              ">
                        <a asp-controller="Transactions" asp-action="Index" class="btn btn-ghost btn-sm">View All in @Model.Category.Name</a>
                    </div>
                </div>

@section Scripts {
    <script>
        window.ACTIVE_PAGE = "budgetdetail";
        window.USER_NAME = "@(User.Identity?.Name ?? "User")";
    </script>
    <script src="~/js/utils.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/budgets.js" asp-append-version="true"></script>
}

   
