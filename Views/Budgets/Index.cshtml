@model List<FinanceME.Models.Entities.Budget>


@{
    ViewData["Title"] = "Budgets Overview";

}

@section Styles {
    <link rel="stylesheet" href="~/css/budgets.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}


                <button class="btn btn-ghost btn-icon"
                        id="mobile-menu-btn"
                        aria-label="Open menu"
                        style="display: none; margin-bottom: var(--space-md)">
                    <svg width="24"
                         height="24"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>

                <header class="page-header budgets-header page-banner">
                    <div class="page-banner-content">
                        <h1 class="text-display"
                            style="font-size: 32px; margin-bottom: 8px">
                            Budgets
                        </h1>
                        <p class="budgets-subtitle page-banner-subtitle">
                            Manage monthly limits and monitor spending goals.
                        </p>
                    </div>
                    <div class="page-banner-actions">
                        <a asp-controller="Budgets" asp-action="Createbudget" class="btn btn-primary" title="Budgets">Create Budget</a>
                    </div>
                </header>

                <!-- Top Total Metrics -->
                <div class="metrics-grid">
                    <div class="card stat-card">
                        <span class="stat-card__label">Total Budget</span>
                        <span class="stat-card__value">EGP @(ViewBag.TotalBudget?.ToString("N2") ?? "0.00")</span>
                        <div style="margin-top: 8px">
                            <span class="stat-card__delta"
                                  style="
                    background: var(--bg-elevated);
                    color: var(--text-secondary);
                  ">@DateTime.Now.ToString("MMMM yyyy")</span>
                        </div>
                    </div>

                    <div class="card stat-card">
                        <span class="stat-card__label">Total Spent</span>
                        <span class="stat-card__value" style="color: var(--warning)">EGP @(ViewBag.TotalSpent?.ToString("N2") ?? "0.00")</span>
                        <div style="margin-top: 8px">
                            @{
                                decimal totalBudget = ViewBag.TotalBudget ?? 0m;
                                decimal totalSpent = ViewBag.TotalSpent ?? 0m;
                                decimal overallPct = totalBudget > 0 ? Math.Round((totalSpent / totalBudget) * 100, 0) : 0;
                            }
                            <span class="stat-card_delta @(overallPct < 85 ? "stat-card_delta--positive" : "stat-card_delta--negative")">@overallPct% Used</span>
                        </div>
                    </div>

                    <div class="card stat-card">
                        <span class="stat-card__label">Remaining</span>
                        <span class="stat-card__value" style="color: var(--positive)">EGP @(ViewBag.Remaining?.ToString("N2") ?? "0.00")</span>
                        <div style="margin-top: 8px">
                            <span class="stat-card_delta stat-card_delta--positive">On Track</span>
                        </div>
                    </div>
                </div>

                <!-- Section Title -->
                <h2 class="text-display"
                    style="
              font-size: 20px;
              margin-bottom: var(--space-md);
              border-bottom: 1px solid var(--border-subtle);
              padding-bottom: var(--space-xs);
            ">
                    Active Budgets
                </h2>

                <div class="budgets-grid">
                    <!-- CHANGE: Budget cards redesigned to match reference screenshot -->
                    @foreach (var item in Model)
                    {
                        // Compute per-card percentage and remaining server-side
                        var cardPct = item.LimitAmount > 0 ? Math.Round((item.SpentAmount / item.LimitAmount) * 100, 0) : 0;
                        var cardRemaining = item.LimitAmount - item.SpentAmount;
                        var cardColorClass = cardPct < 60 ? "text-safe" : cardPct < 85 ? "text-warning" : "text-danger";

                        <a asp-controller="Budgets" asp-route-id="@item.Id" asp-action="Budgetdetail"
                           class="card budget-card" title="@item.Category?.Name"
                           data-spent="@item.SpentAmount" data-limit="@item.LimitAmount">
                            <div class="budget-header">
                                <div class="budget-icon"
                                     style="background: rgba(76, 142, 245, 0.1); color: var(--accent-blue);">
                                    @* CHANGE: Use category emoji icon if available, SVG fallback otherwise *@
                                    @if (!string.IsNullOrEmpty(item.Category?.Icon))
                                    {
                                        <span style="font-size: 20px">@item.Category.Icon</span>
                                    }
                                    else
                                    {
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"></path>
                                            <path d="M3 5v14a2 2 0 0 0 2 2h16v-5"></path>
                                            <path d="M18 12a2 2 0 0 0 0 4h4v-4z"></path>
                                        </svg>
                                    }
                                </div>

                                <div class="budget-amount-display">
                                    <span class="budget-amount-spent">EGP @item.SpentAmount.ToString("N2")</span>
                                    <span class="budget-amount-total">of EGP @item.LimitAmount.ToString("N2")</span>
                                </div>
                            </div>

                            <h3 class="budget-title">@item.Category?.Name</h3>

                            <div class="progress-container">
                                <div class="progress-meta">
                                    <!-- CHANGE: Per-card percentage and remaining/over-budget -->
                                    <span class="@cardColorClass">@cardPct% used</span>
                                    @if (cardRemaining >= 0)
                                    {
                                        <span>EGP @cardRemaining.ToString("N2") left</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">-EGP @(Math.Abs(cardRemaining).ToString("N2")) over</span>
                                    }
                                </div>
                                <div class="progress-track">
                                    <div class="progress-fill" style="width: 0%"></div>
                                </div>
                            </div>
                        </a>
                    }


                    

                </div>

@section Scripts {
    <script>
        window.ACTIVE_PAGE = "budgets";
        window.USER_NAME = "@(User.Identity?.Name ?? "User")";
    </script>
    <script src="~/js/utils.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/budgets.js" asp-append-version="true"></script>
}