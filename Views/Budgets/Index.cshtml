@{
    ViewData["Title"] = "Budgets Overview";
}

@section Styles {
    <link rel="stylesheet" href="~/css/budgets.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}



    <div class="app-container">
        <div id="sidebar-container"></div>
        <div class="sidebar-overlay" id="sidebar-overlay"></div>

        <div class="main-content">
            <div id="header-container"></div>

            <div class="content-wrapper">
                <button class="btn btn-ghost btn-icon"
                        id="mobile-menu-btn"
                        aria-label="Open menu"
                        style="display: none; margin-bottom: var(--space-md)">
                    <svg width="24"
                         height="24"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>

                <header class="page-header budgets-header page-banner">
                    <div class="page-banner-content">
                        <h1 class="text-display"
                            style="font-size: 32px; margin-bottom: 8px">
                            Budgets
                        </h1>
                        <p class="budgets-subtitle page-banner-subtitle">
                            Manage monthly limits and monitor spending goals.
                        </p>
                    </div>
                    <div class="page-banner-actions">
                    <a asp-controller="Budgets" asp-action="Createbudget" class="btn btn-primary" title="Budgets">Create Budget</a>
                    </div>
                </header>

                <!-- Top Total Metrics -->
                <div class="metrics-grid">
                    <div class="card stat-card">
                        <span class="stat-card__label">Total Budget</span>
                        <span class="stat-card__value">EGP 4,200.00</span>
                        <div style="margin-top: 8px">
                            <span class="stat-card__delta"
                                  style="
                    background: var(--bg-elevated);
                    color: var(--text-secondary);
                  ">March 2026</span>
                        </div>
                    </div>

                    <div class="card stat-card">
                        <span class="stat-card__label">Total Spent</span>
                        <span class="stat-card__value" style="color: var(--warning)">EGP 3,150.00</span>
                        <div style="margin-top: 8px">
                            <span class="stat-card__delta stat-card__delta--negative">75% Used</span>
                        </div>
                    </div>

                    <div class="card stat-card">
                        <span class="stat-card__label">Remaining</span>
                        <span class="stat-card__value" style="color: var(--positive)">EGP 1,050.00</span>
                        <div style="margin-top: 8px">
                            <span class="stat-card__delta stat-card__delta--positive">On Track</span>
                        </div>
                    </div>
                </div>

                <!-- Section Title -->
                <h2 class="text-display"
                    style="
              font-size: 20px;
              margin-bottom: var(--space-md);
              border-bottom: 1px solid var(--border-subtle);
              padding-bottom: var(--space-xs);
            ">
                    Active Budgets
                </h2>

                <div class="budgets-grid">
                    <!-- Safe Budget -->
                <a asp-controller="Budgets" asp-action="Budgetdetail" class="card budget-card" title="Budgets">
                        <div class="budget-header">
                            <div>
                                <div class="budget-icon"
                                     style="
                      background: rgba(76, 142, 245, 0.1);
                      color: var(--accent-blue);
                    ">
                                    <svg width="20"
                                         height="20"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="2"
                                         stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                                        <polyline points="9 22 9 12 15 12 15 22"></polyline>
                                    </svg>
                                </div>
                                <h3 class="budget-title">Housing</h3>
                            </div>
                            <div class="budget-amount-display">
                                <span class="budget-amount-spent">EGP 1,800.00</span>
                                <span class="budget-amount-total">of EGP 1,800.00</span>
                            </div>
                        </div>
                        <div class="progress-container">
                            <div class="progress-meta">
                                <span class="text-safe">100% used</span>
                                <span>EGP 0 left</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill fill-safe"
                                     style="width: 100%"></div>
                            </div>
                        </div>
                    </a>

                    <!-- Warning Budget -->
                    

                    <!-- Danger Budget -->
                    

                    <!-- Good Budget -->
                    
                </div>
            </div>

            <div id="footer-container"></div>
        </div>
    </div>

 


  
@section Scripts {
    <script>
        window.ACTIVE_PAGE = "budgets";
        window.USER_NAME = "@(User.Identity?.Name ?? "User")";
    </script>
    <script src="~/js/utils.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/budgets.js" asp-append-version="true"></script>
}