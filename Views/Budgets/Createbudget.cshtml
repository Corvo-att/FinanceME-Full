@model FinanceME.Models.Entities.Budget
@using FinanceME.Enums

@{
    ViewData["Title"] = "Create Budget Overview";
}

@section Styles {
    <link rel="stylesheet" href="~/css/budgets.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}

                <div class="form-container">
                    <header class="page-header">

                        <a asp-controller="Budgets" asp-action="Index" class="btn btn-ghost btn-sm" title="Budgets"
                           style="
                        display: inline-flex;
                        align-items: center;
                        margin-bottom: var(--space-md);
                        margin-left: -8px;
                        ">
                            <svg width="16"
                                 height="16"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2"
                                 stroke-linecap="round"
                                 stroke-linejoin="round"
                                 style="margin-right: 4px">
                                <line x1="19" y1="12" x2="5" y2="12"></line>
                                <polyline points="12 19 5 12 12 5"></polyline>
                            </svg>
                            Back to Budgets
                        </a>


                        <h1 class="text-display" style="font-size: 28px">
                            Create Budget
                        </h1>

                    </header>

                    <form asp-controller="Budgets" asp-action="Savebudget" method="post" class="card" style="padding: var(--space-xl)">
                        <div asp-validation-summary="All" class="text-danger"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="CategoryId" class="form-label">CATEGORY</label>
                            <select asp-for="CategoryId" class="form-input" asp-items="ViewBag.CategoryId">
                                <option value="">Select Category</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>


                        <div class="form-group" style="margin-bottom: var(--space-lg)">

                            <label asp-for="LimitAmount" class="form-label">Monthly Limit</label>

                            <div class="amount-input-wrapper">
                                <span class="currency-symbol">$</span>


                                <input asp-for="LimitAmount"
                                       class="form-input"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       placeholder="0.00"
                                       required />
                            </div>

                            <span asp-validation-for="LimitAmount" class="text-danger"></span>
                        </div>

                        <div class="form-group" style="margin-bottom: var(--space-lg)">
                            <label asp-for="Period" class="form-label">Time Period</label>
                            <select asp-for="Period" asp-items="Html.GetEnumSelectList<BudgetPeriod>()" class="form-input"></select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Rollover Rules</label>
                            <div style="
                    display: flex;
                    flex-direction: column;
                    gap: var(--space-sm);
                    margin-top: var(--space-xs);
                  ">
                                <!-- CHANGE: Bound to Budget.RolloverUnused so value is saved -->
                                <label style="
                      display: flex;
                      align-items: center;
                      gap: 8px;
                      color: var(--text-primary);
                      cursor: pointer;
                      font-size: 14px;
                    ">
                                    <input asp-for="RolloverUnused"
                                           type="checkbox"
                                           style="
                        accent-color: var(--accent-gold);
                        width: 16px;
                        height: 16px;
                      " />
                                    Rollover unused funds to the next month
                                </label>
                                <!-- CHANGE: Bound to Budget.AlertOnThreshold so value is saved -->
                                <label style="
                      display: flex;
                      align-items: center;
                      gap: 8px;
                      color: var(--text-primary);
                      cursor: pointer;
                      font-size: 14px;
                    ">
                                    <input asp-for="AlertOnThreshold"
                                           type="checkbox"
                                           style="
                        accent-color: var(--accent-gold);
                        width: 16px;
                        height: 16px;
                      " />
                                    Alert me when I reach 80% of limit
                                </label>
                            </div>
                        </div>

                        <div class="btn-row">
                            <a asp-controller="Budgets" asp-action="Index" class="btn btn-ghost" title="Budgets">Cancel</a>
                            <button type="submit" class=" btn btn-primary">Save Budget</button>
                        </div>
                    </form>
                </div>
@section Scripts {
    <script>
        window.ACTIVE_PAGE = "createbudget";
        window.USER_NAME = "@(User.Identity?.Name ?? "User")";
    </script>
    <script src="~/js/utils.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/budgets.js" asp-append-version="true"></script>

}
