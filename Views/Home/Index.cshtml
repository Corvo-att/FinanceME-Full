@{
    Layout = null;
    ViewData["Title"] = "FinanceME – Personal Finance, Simplified";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FinanceME is your personal finance command center — track spending, budgets, goals, and accounts in one place." />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/Logo/logo_transparent.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
</head>
<body class="landing-page">

    <!-- ══════════════════════════════════════════════
         NAVBAR
    ══════════════════════════════════════════════ -->
    <header class="landing-nav" id="landing-nav">
        <a class="landing-nav__logo" asp-controller="Home" asp-action="Index">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Finance<span>ME</span>
        </a>

        <nav aria-label="Main navigation">
            <ul class="landing-nav__links" id="mobile-menu">
                <li><a href="#features">Features</a></li>
                <li><a href="#how-it-works">How it works</a></li>
                <li><a href="#stats">By the numbers</a></li>
                <li><a href="#pricing">Pricing</a></li>
                <li><a href="#testimonials">Reviews</a></li>
            </ul>
        </nav>

        <div class="landing-nav__actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn-nav-login" asp-controller="Accounts" asp-action="Index">Open App</a>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post" style="display:inline">
                    <button type="submit" class="btn-nav-cta">Logout</button>
                </form>
            }
            else
            {
                <a class="btn-nav-login" asp-area="Identity" asp-page="/Account/Login">Login</a>
                <a class="btn-nav-cta" asp-area="Identity" asp-page="/Account/Register">Get started</a>
            }
            <button class="landing-nav__hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
                <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="19" y2="6"/>
                    <line x1="3" y1="11" x2="19" y2="11"/>
                    <line x1="3" y1="16" x2="19" y2="16"/>
                </svg>
            </button>
        </div>
    </header>

    <main>
        <!-- ══════════════════════════════════════════════
             HERO
        ══════════════════════════════════════════════ -->
        <section class="hero" id="hero">
            <div class="hero__orb hero__orb--1"></div>
            <div class="hero__orb hero__orb--2"></div>
            <div class="hero__orb hero__orb--3"></div>

            <div class="hero__inner">
                <div class="hero__content">
                    <div class="hero__badge">
                        <div class="hero__badge-dot"></div>
                        Personal Finance, Simplified
                    </div>
                    <h1 class="hero__title">Track spending, <em>budgets</em>, goals, and accounts in one place.</h1>
                    <p class="hero__subtitle">FinanceME gives you a clear command center for every financial decision — from daily spending to long-term wealth planning.</p>
                    <div class="hero__ctas">
                        <a class="btn-hero-primary" asp-area="Identity" asp-page="/Account/Register">
                            <span class="btn-shimmer"></span>
                            Start for free
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </a>
                        <a class="btn-hero-secondary" href="#features">
                            See features
                        </a>
                    </div>
                    <div class="hero__trust">
                        <div class="hero__trust-avatars">
                            <div class="hero__trust-avatar" style="background: #4c8ef5;">AS</div>
                            <div class="hero__trust-avatar" style="background: #c9a84c;">ME</div>
                            <div class="hero__trust-avatar" style="background: #2ecc8a;">ID</div>
                        </div>
                        <p class="hero__trust-text">Secured by <strong>ASP.NET Core Identity</strong> &mdash; bank-grade authentication.</p>
                    </div>
                </div>

                <div class="hero__visual">
                    <div class="hero__mockup">
                        <div class="hero__mockup-header">
                            <div class="dot dot--red"></div>
                            <div class="dot dot--yellow"></div>
                            <div class="dot dot--green"></div>
                            <span class="hero__mockup-title">FinanceME &bull; Dashboard</span>
                        </div>
                        <div class="hero__mockup-body">
                            <div class="mock-stat">
                                <span class="mock-stat__label">Net Worth</span>
                                <span class="mock-stat__value mock-stat__value--gold">£112,891</span>
                            </div>
                            <div class="mock-stat">
                                <span class="mock-stat__label">Monthly Delta</span>
                                <span class="mock-stat__value mock-stat__value--positive">+£4,038</span>
                            </div>
                            <div class="mock-stat">
                                <span class="mock-stat__label">Budget Health</span>
                                <span class="mock-stat__value">87%</span>
                            </div>

                            <div class="mock-chart">
                                <span class="mock-chart__label">Cash Flow (30 Days)</span>
                                <svg viewBox="0 0 100 40" preserveAspectRatio="none">
                                    <!-- filled area — stays well inside the 40-unit tall viewBox -->
                                    <path d="M0,40 L0,28 Q10,22 20,30 T40,26 T60,28 T80,16 T100,12 L100,40 Z"
                                          fill="rgba(201,168,76,0.12)" />
                                    <!-- the animated line — never touches y=0 or y=40 edges -->
                                    <path d="M0,28 Q10,22 20,30 T40,26 T60,28 T80,16 T100,12"
                                          fill="none"
                                          stroke="var(--accent-gold)"
                                          stroke-width="1.8"
                                          stroke-linecap="round"
                                          stroke-linejoin="round" />
                                </svg>
                            </div>

                            <div class="mock-transactions">
                                <div class="mock-tx">
                                    <div class="mock-tx__icon" style="background:rgba(46,204,138,0.12);color:#2ecc8a;">+</div>
                                    <span class="mock-tx__name">Salary Deposit</span>
                                    <span class="mock-tx__amount mock-tx__amount--positive">+£4,200</span>
                                </div>
                                <div class="mock-tx">
                                    <div class="mock-tx__icon" style="background:rgba(224,92,92,0.12);color:#e05c5c;">-</div>
                                    <span class="mock-tx__name">Groceries</span>
                                    <span class="mock-tx__amount mock-tx__amount--negative">-£420</span>
                                </div>
                                <div class="mock-tx">
                                    <div class="mock-tx__icon" style="background:rgba(76,142,245,0.12);color:#4c8ef5;">⬆</div>
                                    <span class="mock-tx__name">Investment Top-up</span>
                                    <span class="mock-tx__amount mock-tx__amount--positive">+£1,000</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════════════════════════════════════════
             TRUSTED STRIP — scrolling brand logos
        ══════════════════════════════════════════════ -->
        <div class="trusted-strip">
            <p class="trusted-strip__label">Tracks the institutions you already use</p>
            <div class="trusted-strip__track" aria-hidden="true">
                <span class="trusted-strip__logo">Chase</span>
                <span class="trusted-strip__logo">Fidelity</span>
                <span class="trusted-strip__logo">Vanguard</span>
                <span class="trusted-strip__logo">American Express</span>
                <span class="trusted-strip__logo">Wells Fargo</span>
                <span class="trusted-strip__logo">Coinbase</span>
                <span class="trusted-strip__logo">Kraken</span>
                <span class="trusted-strip__logo">Charles Schwab</span>
                <!-- duplicate for seamless loop -->
                <span class="trusted-strip__logo">Chase</span>
                <span class="trusted-strip__logo">Fidelity</span>
                <span class="trusted-strip__logo">Vanguard</span>
                <span class="trusted-strip__logo">American Express</span>
                <span class="trusted-strip__logo">Wells Fargo</span>
                <span class="trusted-strip__logo">Coinbase</span>
                <span class="trusted-strip__logo">Kraken</span>
                <span class="trusted-strip__logo">Charles Schwab</span>
                <!-- third set to keep the math right -->
                <span class="trusted-strip__logo">Chase</span>
                <span class="trusted-strip__logo">Fidelity</span>
                <span class="trusted-strip__logo">Vanguard</span>
                <span class="trusted-strip__logo">American Express</span>
                <span class="trusted-strip__logo">Wells Fargo</span>
                <span class="trusted-strip__logo">Coinbase</span>
                <span class="trusted-strip__logo">Kraken</span>
                <span class="trusted-strip__logo">Charles Schwab</span>
                <!-- fourth set -->
                <span class="trusted-strip__logo">Chase</span>
                <span class="trusted-strip__logo">Fidelity</span>
                <span class="trusted-strip__logo">Vanguard</span>
                <span class="trusted-strip__logo">American Express</span>
                <span class="trusted-strip__logo">Wells Fargo</span>
                <span class="trusted-strip__logo">Coinbase</span>
                <span class="trusted-strip__logo">Kraken</span>
                <span class="trusted-strip__logo">Charles Schwab</span>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════
             FEATURES
        ══════════════════════════════════════════════ -->
        <section class="landing-section features" id="features">
            <div class="section-center section-heading reveal">
                <span class="section-label">Everything you need</span>
                <h2 class="section-title">Control <em>everything</em> from one place.</h2>
                <p class="section-subtitle">We centralize your financial inputs so you can make informed decisions fast — no spreadsheets needed.</p>
            </div>

            <div class="features-grid">
                <div class="feature-card reveal">
                    <div class="feature-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="10" width="18" height="10" rx="2"/><path d="M12 2v8M8 6h8"/></svg>
                    </div>
                    <span class="feature-card__badge">Real-time</span>
                    <h3 class="feature-card__title">Accounts Overview</h3>
                    <p class="feature-card__desc">View all your balances in real-time across bank, credit, investment, crypto, and cash accounts — linked or manual.</p>
                </div>
                <div class="feature-card reveal">
                    <div class="feature-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 9l-5 5-4-4-5 5"/></svg>
                    </div>
                    <span class="feature-card__badge">Smart filtering</span>
                    <h3 class="feature-card__title">Transaction Tracking</h3>
                    <p class="feature-card__desc">Categorize automatically, search instantly, and review every transaction so nothing slips through the cracks.</p>
                </div>
                <div class="feature-card reveal">
                    <div class="feature-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    </div>
                    <h3 class="feature-card__title">Budget &amp; Goals</h3>
                    <p class="feature-card__desc">Set spending limits, monitor budget health and track savings goals — with alerts before you overspend.</p>
                </div>
                <div class="feature-card reveal">
                    <div class="feature-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                    </div>
                    <span class="feature-card__badge">Insights</span>
                    <h3 class="feature-card__title">Rich Analytics</h3>
                    <p class="feature-card__desc">Understand where your money goes with visual breakdowns, spending trends, and income vs expense reports.</p>
                </div>
                <div class="feature-card reveal">
                    <div class="feature-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                    </div>
                    <h3 class="feature-card__title">Bills &amp; Subscriptions</h3>
                    <p class="feature-card__desc">Never miss a bill. FinanceME tracks recurring payments and alerts you before due dates — saving you late fees.</p>
                </div>
                <div class="feature-card reveal">
                    <div class="feature-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </div>
                    <span class="feature-card__badge">Secure</span>
                    <h3 class="feature-card__title">Bank-grade Security</h3>
                    <p class="feature-card__desc">Built on ASP.NET Core Identity with encrypted credentials, account lockout, and audit-ready access control.</p>
                </div>
            </div>
        </section>

        <!-- ══════════════════════════════════════════════
             STATS
        ══════════════════════════════════════════════ -->
        <div class="stats-section" id="stats">
            <div class="stats-inner">
                <div class="stat-item">
                    <div class="stat-item__bar"></div>
                    <span class="stat-item__number" data-count-target="6" data-count-suffix="+">0+</span>
                    <span class="stat-item__label">Account Types</span>
                </div>
                <div class="stat-item">
                    <div class="stat-item__bar"></div>
                    <span class="stat-item__number" data-count-target="100" data-count-suffix="%">0%</span>
                    <span class="stat-item__label">Data Ownership</span>
                </div>
                <div class="stat-item">
                    <div class="stat-item__bar"></div>
                    <span class="stat-item__number" data-count-target="0" data-count-suffix="ms">0ms</span>
                    <span class="stat-item__label">Tracking Delay</span>
                </div>
                <div class="stat-item">
                    <div class="stat-item__bar"></div>
                    <span class="stat-item__number" data-count-target="4.9" data-count-suffix="★">0★</span>
                    <span class="stat-item__label">User Rating</span>
                </div>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════
             HOW IT WORKS
        ══════════════════════════════════════════════ -->
        <section class="landing-section steps" id="how-it-works">
            <div class="section-center section-heading reveal">
                <span class="section-label">How it works</span>
                <h2 class="section-title">Three steps to financial <em>clarity</em>.</h2>
            </div>

            <div class="steps-grid">
                <div class="step-card">
                    <div class="step-card__number">01</div>
                    <div class="step-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <h3 class="step-card__title">Create your account</h3>
                    <p class="step-card__desc">Sign up securely in seconds. ASP.NET Core Identity protects your credentials with hashed passwords and optional two-factor authentication.</p>
                </div>
                <div class="step-connector">
                    <svg viewBox="0 0 60 24" fill="none" stroke="var(--accent-gold)" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.4"><line x1="0" y1="12" x2="60" y2="12"/></svg>
                </div>
                <div class="step-card">
                    <div class="step-card__number">02</div>
                    <div class="step-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                    </div>
                    <h3 class="step-card__title">Add or link accounts</h3>
                    <p class="step-card__desc">Connect checking, savings, credit cards, investments, crypto wallets, or add manual cash accounts. Everything in one place.</p>
                </div>
                <div class="step-connector">
                    <svg viewBox="0 0 60 24" fill="none" stroke="var(--accent-gold)" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.4"><line x1="0" y1="12" x2="60" y2="12"/></svg>
                </div>
                <div class="step-card">
                    <div class="step-card__number">03</div>
                    <div class="step-card__icon">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18 9l-5 5-4-4-5 5"/></svg>
                    </div>
                    <h3 class="step-card__title">Track progress daily</h3>
                    <p class="step-card__desc">Monitor net worth, budgets, and spending habits through the dashboard. Set alerts and watch your financial health improve.</p>
                </div>
            </div>
        </section>

        <!-- ══════════════════════════════════════════════
             PRICING
        ══════════════════════════════════════════════ -->
        <section class="landing-section pricing" id="pricing">
            <div class="section-center section-heading reveal">
                <span class="section-label">Simple pricing</span>
                <h2 class="section-title">Start free, <em>grow</em> when you're ready.</h2>
                <p class="section-subtitle">No hidden fees. No credit card required to start. Cancel anytime.</p>
            </div>

            <div class="pricing-toggle">
                <span class="pricing-toggle__label active" data-toggle="monthly">Monthly</span>
                <button class="pricing-toggle__switch" aria-pressed="false" aria-label="Toggle yearly billing">
                    <span class="pricing-toggle__knob"></span>
                </button>
                <span class="pricing-toggle__label" data-toggle="yearly">
                    Yearly
                    <span class="pricing-toggle__save">Save 20%</span>
                </span>
            </div>

            <div class="pricing-grid">
                <!-- Free -->
                <div class="pricing-card reveal">
                    <h3 class="pricing-card__name">Free</h3>
                    <div class="pricing-card__price">
                        <span class="currency">E£</span>
                        <span class="amount" data-price-monthly="0" data-price-yearly="0">0</span>
                        <span class="period">/ month</span>
                    </div>
                    <p class="pricing-card__desc">Perfect for individuals just getting started with personal finance.</p>
                    <ul class="pricing-card__features">
                        <li><span class="check">✓</span> Up to 3 linked accounts</li>
                        <li><span class="check">✓</span> Transaction history (90 days)</li>
                        <li><span class="check">✓</span> Basic budget tracking</li>
                        <li><span class="check">✓</span> Monthly spending summary</li>
                        <li><span class="check" style="opacity:.3">✗</span> <span style="opacity:.4">Analytics &amp; insights</span></li>
                        <li><span class="check" style="opacity:.3">✗</span> <span style="opacity:.4">Bills &amp; subscriptions</span></li>
                    </ul>
                    <a class="btn-pricing btn-pricing--outline" asp-area="Identity" asp-page="/Account/Register">Get started free</a>
                </div>

                <!-- Pro (featured) -->
                <div class="pricing-card pricing-card--featured reveal">
                    <span class="pricing-card__badge">Most Popular</span>
                    <h3 class="pricing-card__name">Pro</h3>
                    <div class="pricing-card__price">
                        <span class="currency">E£</span>
                        <span class="amount" data-price-monthly="149" data-price-yearly="119">149</span>
                        <span class="period">/ month</span>
                    </div>
                    <p class="pricing-card__desc">Full financial command center for serious individuals and families.</p>
                    <ul class="pricing-card__features">
                        <li><span class="check">✓</span> Unlimited linked accounts</li>
                        <li><span class="check">✓</span> Full transaction history</li>
                        <li><span class="check">✓</span> Advanced budget &amp; goals</li>
                        <li><span class="check">✓</span> Rich analytics &amp; reports</li>
                        <li><span class="check">✓</span> Bills &amp; subscription tracking</li>
                        <li><span class="check">✓</span> Alert &amp; notification rules</li>
                    </ul>
                    <a class="btn-pricing btn-pricing--gold" asp-area="Identity" asp-page="/Account/Register">Start Pro trial</a>
                </div>

                <!-- Family/Enterprise -->
                <div class="pricing-card reveal">
                    <h3 class="pricing-card__name">Family</h3>
                    <div class="pricing-card__price">
                        <span class="currency">E£</span>
                        <span class="amount" data-price-monthly="299" data-price-yearly="239">299</span>
                        <span class="period">/ month</span>
                    </div>
                    <p class="pricing-card__desc">Shared household finances with individual dashboards for each member.</p>
                    <ul class="pricing-card__features">
                        <li><span class="check">✓</span> Up to 6 household members</li>
                        <li><span class="check">✓</span> All Pro features</li>
                        <li><span class="check">✓</span> Shared &amp; private budgets</li>
                        <li><span class="check">✓</span> Joint account visibility</li>
                        <li><span class="check">✓</span> Household net worth view</li>
                        <li><span class="check">✓</span> Priority support</li>
                    </ul>
                    <a class="btn-pricing btn-pricing--outline" asp-area="Identity" asp-page="/Account/Register">Start Family trial</a>
                </div>
            </div>
        </section>

        <!-- ══════════════════════════════════════════════
             TESTIMONIALS
        ══════════════════════════════════════════════ -->
        <section class="landing-section testimonials" id="testimonials">
            <div class="section-center section-heading reveal">
                <span class="section-label">What people say</span>
                <h2 class="section-title">Loved by people who <em>manage money seriously</em>.</h2>
            </div>

            <div class="testimonials-grid">
                <div class="testimonial-card reveal">
                    <div class="testimonial-card__stars">★★★★★</div>
                    <p class="testimonial-card__text">"Finally a finance app that doesn't feel like a homework assignment. The accounts overview alone is worth it — I can see everything at a glance."</p>
                    <div class="testimonial-card__author">
                        <div class="testimonial-card__avatar-ring">
                            <div class="testimonial-card__avatar">SR</div>
                        </div>
                        <div>
                            <span class="testimonial-card__name">Sara R.</span>
                            <span class="testimonial-card__role">Freelance Designer</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card reveal">
                    <div class="testimonial-card__stars">★★★★★</div>
                    <p class="testimonial-card__text">"The budget tracking is insanely accurate. I caught three forgotten subscriptions in my first week. That alone paid for itself."</p>
                    <div class="testimonial-card__author">
                        <div class="testimonial-card__avatar-ring">
                            <div class="testimonial-card__avatar">KM</div>
                        </div>
                        <div>
                            <span class="testimonial-card__name">Karim M.</span>
                            <span class="testimonial-card__role">Software Engineer</span>
                        </div>
                    </div>
                </div>
                <div class="testimonial-card reveal">
                    <div class="testimonial-card__stars">★★★★★</div>
                    <p class="testimonial-card__text">"I've tried every personal finance app out there. FinanceME is the only one with a design that matches how seriously I take my money."</p>
                    <div class="testimonial-card__author">
                        <div class="testimonial-card__avatar-ring">
                            <div class="testimonial-card__avatar">NE</div>
                        </div>
                        <div>
                            <span class="testimonial-card__name">Nour E.</span>
                            <span class="testimonial-card__role">Financial Analyst</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ══════════════════════════════════════════════
             CTA
        ══════════════════════════════════════════════ -->
        <section class="cta-section">
            <div class="cta-orb cta-orb--1"></div>
            <div class="cta-orb cta-orb--2"></div>
            <div class="cta-section__inner">
                <span class="section-label">Ready to start?</span>
                <h2 class="cta-section__title">Take control of your <em>financial future</em> today.</h2>
                <p class="cta-section__subtitle">Join people who stopped guessing and started knowing — exactly where every pound goes.</p>
                <div class="cta-section__buttons">
                    <a class="btn-hero-primary" asp-area="Identity" asp-page="/Account/Register">
                        <span class="btn-shimmer"></span>
                        Create free account
                    </a>
                    <a class="btn-hero-secondary" asp-area="Identity" asp-page="/Account/Login">Sign in</a>
                </div>
                <p class="cta-section__trust">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    No credit card required &bull; Cancel anytime &bull; 100% private
                </p>
            </div>
        </section>
    </main>

    <!-- ══════════════════════════════════════════════
         LANDING FOOTER
    ══════════════════════════════════════════════ -->
    <footer class="landing-footer">
        <div class="landing-footer__inner">
            <div class="landing-footer__brand">
                <a class="landing-nav__logo" asp-controller="Home" asp-action="Index" style="display:inline-flex;margin-bottom:1rem;">
                    Finance<span>ME</span>
                </a>
                <p>Your personal finance command center — built to give you clarity, control, and confidence over every financial decision.</p>
            </div>
            <div class="landing-footer__col">
                <h4>Product</h4>
                <ul>
                    <li><a href="#features">Features</a></li>
                    <li><a href="#pricing">Pricing</a></li>
                    <li><a href="#how-it-works">How it works</a></li>
                    <li><a href="#" aria-disabled="true">Roadmap</a></li>
                </ul>
            </div>
            <div class="landing-footer__col">
                <h4>Account</h4>
                <ul>
                    <li><a asp-area="Identity" asp-page="/Account/Register">Register</a></li>
                    <li><a asp-area="Identity" asp-page="/Account/Login">Login</a></li>
                    <li><a asp-area="Identity" asp-page="/Account/ForgotPassword">Forgot Password</a></li>
                </ul>
            </div>
            <div class="landing-footer__col">
                <h4>Legal</h4>
                <ul>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms of Service</a></li>
                    <li><a href="#">Help Center</a></li>
                    <li><a href="#">Security</a></li>
                </ul>
            </div>
        </div>

        <div class="landing-footer__newsletter">
            <p class="landing-footer__newsletter-label">Stay up to date with new features</p>
            <form class="landing-footer__newsletter-form" onsubmit="return false;">
                <input type="email" class="landing-footer__newsletter-input" placeholder="your@email.com" aria-label="Email for newsletter" />
                <button type="submit" class="landing-footer__newsletter-btn">Subscribe</button>
            </form>
        </div>

        <div class="landing-footer__bottom">
            <span class="landing-footer__copyright">&copy; @DateTime.Now.Year FinanceME. All rights reserved. &bull; v1.0.0</span>
            <div class="landing-footer__socials">
                <a href="#" aria-label="GitHub">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                </a>
                <a href="#" aria-label="Twitter / X">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                </a>
                <a href="#" aria-label="LinkedIn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"></script>
    <script src="~/js/landing.js" asp-append-version="true"></script>
</body>
</html>
