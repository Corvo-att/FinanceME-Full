<nav class="sidebar" id="sidebar">
    <!-- Collapse/expand toggle button -->
    <button class="sidebar__toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </button>

    <!-- Logo -->
    <div class="sidebar__logo">
        <img src="~/Logo/logo_transparent.png" alt="FinanceME Logo"
             style="width: 110px; height: 110px; object-fit: contain; margin: -30px -25px -30px -35px;" />
        <span class="sidebar__logo-text">Finance<span class="sidebar__logo-accent">ME</span></span>
    </div>

    <!-- Navigation links -->
    <div class="sidebar__nav">

        <!-- ---- MAIN section ---- -->
        <div class="sidebar__group-label">Main</div>

        <a asp-controller="Home" asp-action="Index" class="sidebar__link" data-page="home" title="Home">

            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            <span class="sidebar__link-text">Home</span>

        </a>

        <!-- ---- FINANCE section ---- -->
        <div class="sidebar__group-label">Finance</div>

        <a asp-controller="Accounts" asp-action="Index" class="sidebar__link" data-page="accounts" title="Accounts">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="M2 10h20"></path>
            </svg>
            <span class="sidebar__link-text">Accounts</span>
        </a>

        <a href="#" class="sidebar__link" data-page="transactions" title="Transactions">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
            <span class="sidebar__link-text">Transactions</span>
        </a>

        <a href="#" class="sidebar__link" data-page="budgets" title="Budgets">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
                <path d="M22 12A10 10 0 0 0 12 2v10z"></path>
            </svg>
            <span class="sidebar__link-text">Budgets</span>
        </a>

        <a href="#" class="sidebar__link" data-page="goals" title="Goals">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <circle cx="12" cy="12" r="6"></circle>
                <circle cx="12" cy="12" r="2"></circle>
            </svg>
            <span class="sidebar__link-text">Goals</span>
        </a>

        <!-- ---- ANALYTICS section ---- -->
        <div class="sidebar__group-label">Analytics</div>

        <a href="#" class="sidebar__link" data-page="reports" title="Reports">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10"></line>
                <line x1="12" y1="20" x2="12" y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
            <span class="sidebar__link-text">Reports</span>
        </a>

        <!-- ---- PLANNING section ---- -->
        <div class="sidebar__group-label">Planning</div>

        <a href="#" class="sidebar__link" data-page="bills" title="Bills">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span class="sidebar__link-text">Bill Calendar</span>
        </a>

        <a href="#" class="sidebar__link" data-page="forecast" title="Forecast">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
            <span class="sidebar__link-text">Forecast</span>
        </a>

        <a href="#" class="sidebar__link" data-page="debt-payoff" title="Debt Payoff Planner">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 1v22"></path>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
            <span class="sidebar__link-text">Debt Payoff</span>
        </a>

        <a href="#" class="sidebar__link" data-page="investment-projector" title="Retirement &amp; Investment Projector">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 20V10"></path>
                <path d="M18 20V4"></path>
                <path d="M6 20v-5"></path>
            </svg>
            <span class="sidebar__link-text">Investment</span>
        </a>

        <!-- ---- SYSTEM section ---- -->
        <div class="sidebar__group-label">System</div>

        <a href="#" class="sidebar__link" data-page="notifications" title="Notifications">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
            </svg>
            <span class="sidebar__link-text">Notifications</span>
        </a>

        <a href="#" class="sidebar__link" data-page="settings" title="Settings">
            <svg class="sidebar__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
