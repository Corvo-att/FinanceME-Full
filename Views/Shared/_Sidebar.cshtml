            </svg>
            <span class="sidebar__link-text">Settings</span>
        </a>

    </div>

    <!-- User info at the bottom -->
    <div class="sidebar__user">
        <a href="#" class="sidebar__user-link" title="Profile Settings">
            <div class="sidebar__avatar" id="sidebar-avatar">
                @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
            </div>
            <span class="sidebar__user-name" id="sidebar-user-name">
                @(User.Identity?.Name ?? "User")
            </span>
        </a>
        <form asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home")"
              method="post" class="sidebar__user-menu">
            <button type="submit" class="btn-ghost btn-icon btn-sm" aria-label="Sign out" title="Sign out">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
            </button>
        </form>
