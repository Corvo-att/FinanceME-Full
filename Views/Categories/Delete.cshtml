@model FinanceME.Models.Entities.Category

@{
    ViewData["Title"] = "Delete Category";
}

@section Styles {
    <link rel="stylesheet" href="~/css/transactions.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}

<div class="form-container">
    <header class="page-header">
        <a asp-action="Index" class="btn btn-ghost btn-sm" style="display: inline-flex; align-items: center; margin-bottom: var(--space-md); margin-left: -8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to Categories
        </a>
    </header>

    <div class="card border-danger" style="padding: var(--space-xl); max-width: 600px; margin: 40px auto; border: 1px solid var(--danger);">
        <div style="text-align: center; margin-bottom: var(--space-lg);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: var(--space-sm);">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <h2 class="text-display text-danger" style="font-size: 24px; margin-bottom: 8px;">Delete Category?</h2>
            <p class="text-secondary">Are you sure you want to delete this category? It will no longer be available for transactions or budgets.</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: var(--space-md);"></div>

        <div class="tx-hero" style="text-align: center; margin-bottom: var(--space-xl)">
            <div class="tx-amount" style="font-size: 32px; font-weight: bold; font-family: var(--font-ui); display: inline-flex; align-items: center;">
                @if (!string.IsNullOrEmpty(Model?.Color))
                {
                    <span style="background: @Model?.Color; width: 24px; height: 24px; border-radius: 50%; display: inline-block; margin-right: 12px;"></span>
                }
                @Model?.Name
            </div>
        </div>

        <div class="detail-list" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div class="detail-row" style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: var(--space-sm);">
                <span class="detail-label text-secondary">Type</span>
                <span class="detail-value" style="font-weight: 500;">@(Model?.IsDefault == true ? "System Category" : "Custom Category")</span>
            </div>
            @if (Model?.ParentCategory != null)
            {
                <div class="detail-row" style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: var(--space-sm);">
                    <span class="detail-label text-secondary">Parent</span>
                    <span class="detail-value" style="font-weight: 500;">@Model?.ParentCategory?.Name</span>
                </div>
            }
        </div>

        <div style="margin-top: var(--space-xl);">
            <form asp-action="Delete" style="display: flex; gap: var(--space-sm);">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-ghost" style="flex: 1; justify-content: center; background-color: var(--surface-hover);">Cancel</a>
                
                @if (ViewBag.IsInUse == true || Model?.IsDefault == true)
                {
                    <button type="submit" class="btn btn-danger" style="flex: 1; justify-content: center; background-color: var(--danger); color: white; opacity: 0.5; pointer-events: none;" disabled>Delete Permanently</button>
                }
                else
                {
                    <button type="submit" class="btn btn-danger" style="flex: 1; justify-content: center; background-color: var(--danger); color: white;">Delete Permanently</button>
                }
            </form>
        </div>
    </div>
</div>