@model IEnumerable<FinanceME.Models.Entities.Category>

@{
    ViewData["Title"] = "Categories";
}

@section Styles {
    <link rel="stylesheet" href="~/css/transactions.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}

<header class="transactions-header page-banner">
    <div class="page-banner-content">
        <h1 class="text-display" style="font-size: 28px; font-family: var(--font-ui)">Categories</h1>
        <p class="transactions-subtitle page-banner-subtitle">
            Manage how you classify your transactions and budgets. 
        </p>
    </div>
    <div class="transactions-actions page-banner-actions">
        <a asp-action="Create" class="btn btn-primary" style="display: inline-flex; align-items: center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0A0A0F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Add Category
        </a>
    </div>
</header>

<!-- Filter Bar Mock -->
<div class="filter-bar">
    <div class="input-group">
        <label for="filter-search">Search</label>
        <input type="text" id="filter-search" placeholder="Find a category..." />
    </div>
</div>

<div class="card">
    <table class="data-table" style="width: 100%">
        <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Parent Category</th>
                <th style="text-align: right">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-weight: 500">
                        @if (!string.IsNullOrEmpty(item.Color))
                        {
                            <span class="category-dot" style="background: @item.Color; display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 8px;"></span>
                        }
                        else
                        {
                            <span class="category-dot" style="background: var(--text-muted); display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 8px;"></span>
                        }
                        @item.Name
                    </td>
                    <td>@(item.IsDefault ? "System" : "Custom")</td>
                    <td class="text-secondary">-</td>
                    <td style="text-align: right">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-ghost btn-sm">Details</a> |
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-ghost btn-sm">Edit</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-ghost btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
                @foreach (var subItem in item.SubCategories)
                {
                    <tr>
                        <td style="padding-left: 30px; font-weight: 400">
                            @if (!string.IsNullOrEmpty(subItem.Color))
                            {
                                <span class="category-dot" style="background: @subItem.Color; display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 8px;"></span>
                            }
                            else
                            {
                                <span class="category-dot" style="background: var(--text-muted); display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 8px;"></span>
                            }
                            @subItem.Name
                        </td>
                        <td>@(subItem.IsDefault ? "System" : "Custom")</td>
                        <td class="text-secondary">@item.Name</td>
                        <td style="text-align: right">
                            <a asp-action="Details" asp-route-id="@subItem.Id" class="btn btn-ghost btn-sm">Details</a> |
                            <a asp-action="Edit" asp-route-id="@subItem.Id" class="btn btn-ghost btn-sm">Edit</a> |
                            <a asp-action="Delete" asp-route-id="@subItem.Id" class="btn btn-ghost btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            }
            @if(!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted" style="padding: var(--space-xl) 0;">No categories found. View system defaults or add custom tracking categories.</td>
                </tr>
            }
        </tbody>
    </table>
</div>