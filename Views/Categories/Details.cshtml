@model FinanceME.Models.Entities.Category

@{
    ViewData["Title"] = "Category Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/transactions.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}

<div class="form-container">
    <header class="page-header">
        <a asp-action="Index" class="btn btn-ghost btn-sm" style="display: inline-flex; align-items: center; margin-bottom: var(--space-md); margin-left: -8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to Categories
        </a>
    </header>

    <div class="card" style="padding: var(--space-xl); max-width: 600px; margin: 40px auto;">
        <div class="tx-hero" style="text-align: center; margin-bottom: var(--space-xl)">
            <div class="tx-amount" style="font-size: 32px; font-weight: bold; font-family: var(--font-ui); display: inline-flex; align-items: center;">
                @if (!string.IsNullOrEmpty(Model?.Color))
                {
                    <span style="background: @Model?.Color; width: 24px; height: 24px; border-radius: 50%; display: inline-block; margin-right: 12px;"></span>
                }
                @Model?.Name
            </div>
            <div class="tx-merchant text-secondary" style="font-size: 16px;">
                @(Model?.IsDefault == true ? "System Category" : "Custom Category")
            </div>
        </div>

        <div class="detail-list" style="display: flex; flex-direction: column; gap: var(--space-md);">
            <div class="detail-row" style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: var(--space-sm);">
                <span class="detail-label text-secondary">Id</span>
                <span class="detail-value" style="font-weight: 500;">@Model?.Id</span>
            </div>

            @if (Model?.ParentCategory != null)
            {
                <div class="detail-row" style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: var(--space-sm);">
                    <span class="detail-label text-secondary">Parent Category</span>
                    <span class="detail-value" style="font-weight: 500;">@Model?.ParentCategory.Name</span>
                </div>
            }

            <div class="detail-row" style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: var(--space-sm);">
                <span class="detail-label text-secondary">Created At</span>
                <span class="detail-value" style="font-weight: 500;">@Model?.CreatedAt.ToString("MMM dd, yyyy")</span>
            </div>

            @if (Model?.SubCategories?.Any() == true)
            {
                <div class="detail-row" style="display: flex; flex-direction: column; margin-top: var(--space-sm);">
                    <span class="detail-label text-secondary" style="margin-bottom: 8px;">Sub-Categories</span>
                    <div style="background: var(--surface); padding: var(--space-sm); border-radius: var(--radius-sm); display: flex; flex-wrap: wrap; gap: 8px;">
                        @foreach(var sub in Model.SubCategories)
                        {
                            <span class="badge badge-primary">@sub.Name</span>
                        }
                    </div>
                </div>
            }
        </div>

        <div style="margin-top: var(--space-xl); display: flex; gap: var(--space-sm); justify-content: center;">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary" style="flex: 1; justify-content: center;">Edit Category</a>
            <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-ghost text-danger" style="flex: 1; justify-content: center; background-color: var(--surface-hover);">Delete</a>
        </div>
    </div>
</div>