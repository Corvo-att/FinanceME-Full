@model FinanceME.Models.Entities.Category

@{
    ViewData["Title"] = "Add Category";
}

@section Styles {
    <link rel="stylesheet" href="~/css/transactions.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/b9a020078f.js" crossorigin="anonymous"></script>
}

<div class="form-container">
    <header class="transactions-header page-banner">
        <div class="page-banner-content">
            <h1 class="text-display" style="font-size: 28px; font-family: var(--font-ui)">Add Category</h1>
        </div>
        <div class="page-banner-actions">
            <a asp-action="Index" class="btn btn-ghost" style="display: inline-flex; align-items: center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Back
            </a>
        </div>
    </header>

    <div class="card" style="margin: 40px auto; max-width: 600px; padding: var(--space-xl)">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label">Category Name</label>
                <input asp-for="Name" class="form-input" placeholder="e.g. Groceries" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Icon" class="form-label">Icon (optional)</label>
                <input asp-for="Icon" class="form-input" placeholder="e.g. string or emoji" />
                <span asp-validation-for="Icon" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Color" class="form-label">Color (optional hex code)</label>
                <input asp-for="Color" class="form-input" type="color" style="height: 40px;" />
                <span asp-validation-for="Color" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ParentCategoryId" class="form-label">Parent Category (Optional)</label>
                <select asp-for="ParentCategoryId" class="form-input" asp-items="ViewBag.ParentCategoryId">
                    <option value="">-- None (Top Level) --</option>
                </select>
                <span asp-validation-for="ParentCategoryId" class="text-danger"></span>
            </div>

            <div class="mt-4" style="margin-top: var(--space-xl)">
                <input type="submit" value="Add Category" class="btn btn-primary" style="width: 100%" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}